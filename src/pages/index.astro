---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import SearchWidgets from '@/components/SearchWidgets.astro';
import TopicVocabulary from '@/components/TopicVocabulary.astro';

export const prerender = true;
---

<BaseLayout>
  <div class="page">
    <Header activePage="home" />

    <!-- ── Search Hero ── -->
    <section class="hero">
      <div class="hero-inner">
        <h1 class="hero-title">Tra cứu Hán Việt</h1>
        <p class="hero-sub">Tìm kiếm chữ Hán, pinyin, Hán Việt hoặc nghĩa tiếng Việt</p>

        <!-- Search bar -->
        <div class="search-area" role="search">
          <div class="search-wrapper" id="search-wrapper">
            <span class="search-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.35-4.35"/>
              </svg>
            </span>
            <input
              type="search"
              id="search-input"
              class="search-input"
              placeholder="Nhập chữ Hán, pinyin hoặc nghĩa..."
              autocomplete="off"
              spellcheck="false"
              aria-label="Tìm kiếm từ vựng"
              aria-controls="results"
              aria-autocomplete="list"
            />
            <span class="search-spinner" id="search-spinner" aria-hidden="true"></span>
            <button class="search-clear" id="search-clear" type="button" aria-label="Xóa" hidden>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M18 6 6 18M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <!-- Filter tabs -->
          <div class="filter-tabs" role="tablist" aria-label="Loại tìm kiếm">
            <button class="filter-tab filter-tab--active" role="tab" aria-selected="true" data-tab="vocab">Từ vựng</button>
            <button class="filter-tab" role="tab" aria-selected="false" data-tab="hanzi">Hán tự</button>
            <button class="filter-tab" role="tab" aria-selected="false" data-tab="example">Ví dụ</button>
            <button class="filter-tab" role="tab" aria-selected="false" data-tab="grammar">Ngữ pháp</button>
            <button class="filter-tab" role="tab" aria-selected="false" data-tab="idiom">Thành ngữ</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Main content ── -->
    <main class="main-area" aria-live="polite">
      <div class="container">

        <!-- Search results (shown when searching) -->
        <section id="search-section" class="hidden">
          <div class="section-hdr">
            <span class="section-label" id="results-label">Kết quả tìm kiếm</span>
          </div>
          <div id="results" class="results-grid" role="list"></div>
          <div id="empty-state" class="state-msg hidden"></div>
          <div id="error-state" class="state-msg error hidden"></div>
        </section>

        <!-- Idle dashboard (shown when not searching) -->
        <section id="history-section">
          <!-- History card -->
          <div class="dash-card" id="history-card">
            <div class="dash-card-header" id="history-header" style="display:none">
              <h2 class="dash-card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                Lịch sử tra cứu
              </h2>
              <button class="btn-sm" id="clear-history-btn" type="button">Xóa tất cả</button>
            </div>
            <div id="history-grid" class="results-grid" role="list"></div>
            <div id="history-empty" class="empty-state hidden">
              <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"/>
                  <path d="m21 21-4.35-4.35"/>
                </svg>
              </div>
              <p class="empty-title">Bắt đầu tìm kiếm</p>
              <p class="empty-sub">Nhập từ khóa vào ô tìm kiếm để tra cứu từ điển.</p>
            </div>
          </div>

          <!-- Hot keywords + Query history -->
          <SearchWidgets />

          <!-- Topic vocabulary -->
          <TopicVocabulary />

          <!-- Search Widgets: Hot keywords + History -->
          <SearchWidgets />
        </section>

      </div>
    </main>

    <footer class="footer">
      <p>WenZi © 2026 &mdash; MIT License</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; min-height: 100dvh; }

  /* Hero */
  .hero {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 2.5rem 1.5rem 0;
  }
  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }
  .hero-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--color-text);
  }
  .hero-sub {
    font-size: .9rem;
    color: var(--color-text-muted);
    margin-top: -.5rem;
  }

  /* Search */
  .search-area { width: 100%; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .search-wrapper {
    width: 100%;
    display: flex;
    align-items: center;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: 999px;
    box-shadow: var(--shadow-md);
    transition: border-color .2s, box-shadow .2s;
    overflow: hidden;
  }
  .search-wrapper:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent), var(--shadow-md);
  }
  .search-icon {
    display: flex;
    align-items: center;
    padding: 0 12px 0 20px;
    color: var(--color-text-muted);
    pointer-events: none;
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--color-text);
    font-size: 1rem;
    font-family: var(--font-sans);
    padding: 14px 0;
    min-width: 0;
  }
  .search-input::placeholder { color: var(--color-text-muted); opacity: .7; }
  .search-input::-webkit-search-cancel-button { display: none; }
  .search-spinner {
    display: none;
    width: 18px; height: 18px;
    flex-shrink: 0;
    border: 2.5px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    margin-right: 16px;
    animation: spin .7s linear infinite;
  }
  .search-spinner.active { display: block; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .search-clear {
    display: flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; margin-right: 10px;
    border-radius: 50%; border: none; background: var(--color-border);
    color: var(--color-text-muted); cursor: pointer; flex-shrink: 0;
    transition: background .15s, color .15s;
  }
  .search-clear:hover { background: var(--color-primary); color: #fff; }

  /* Filter tabs */
  .filter-tabs {
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
    justify-content: center;
    padding-bottom: 1rem;
  }
  .filter-tab {
    padding: .4rem 1rem;
    border-radius: 999px;
    font-size: .82rem;
    font-weight: 500;
    border: 1.5px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all .2s;
  }
  .filter-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-dim);
  }
  .filter-tab--active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .filter-tab--active:hover { background: var(--color-primary-hover); }

  /* Main */
  .main-area { flex: 1; padding: 1.75rem 1.5rem 4rem; }
  .container { max-width: 1120px; margin: 0 auto; }

  /* Section header */
  .section-hdr { display: flex; align-items: center; gap: .75rem; margin-bottom: 1rem; }
  .section-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--color-text-muted);
  }

  /* Results grid */
  .results-grid { display: grid; gap: .75rem; grid-template-columns: 1fr; }
  @media (min-width: 560px) { .results-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 820px) { .results-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1080px) { .results-grid { grid-template-columns: repeat(4, 1fr); } }

  /* Dashboard card */
  .dash-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .dash-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 1rem;
  }
  .dash-card-title {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .95rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .btn-sm {
    background: none;
    border: 1.5px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: 8px;
    padding: .3rem .75rem;
    font-size: .78rem;
    cursor: pointer;
    transition: all .15s;
  }
  .btn-sm:hover { border-color: var(--color-primary); color: var(--color-primary); }

  /* Tips grid */
  .tips-grid {
    display: grid;
    gap: .75rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 560px) { .tips-grid { grid-template-columns: repeat(3, 1fr); } }
  .tip-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }
  .tip-icon {
    width: 40px; height: 40px;
    background: var(--color-primary-dim);
    color: var(--color-primary);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tip-title { font-size: .95rem; font-weight: 700; color: var(--color-text); }
  .tip-body { font-size: .84rem; color: var(--color-text-muted); line-height: 1.6; }

  /* Entry cards (JS-rendered) */
  :global(.entry-card) {
    display: flex;
    align-items: stretch;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow .15s, transform .15s;
    animation: fadeIn .18s ease;
    position: relative;
  }
  :global(.entry-card:hover) {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }
  :global(.entry-card.focused) {
    outline: 2.5px solid var(--color-primary);
    outline-offset: 0px;
    box-shadow: var(--shadow-md);
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  :global(.card-accent) {
    background: var(--color-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem .9rem;
    min-width: 70px;
    gap: .2rem;
  }
  :global(.card-simplified) {
    font-size: 1.9rem;
    color: #fff;
    line-height: 1;
    font-weight: 400;
  }
  :global(.card-traditional) {
    font-size: .65rem;
    color: rgba(255,255,255,.65);
    letter-spacing: .03em;
  }
  :global(.card-body) {
    flex: 1;
    padding: .75rem .9rem;
    display: flex;
    flex-direction: column;
    gap: .2rem;
    justify-content: center;
    min-width: 0;
  }
  :global(.card-meaning) {
    font-size: .92rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.card-pinyin) {
    font-size: .8rem;
    font-style: italic;
    color: var(--color-primary);
  }
  :global(.card-hanviet) {
    font-size: .75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(.card-fav) {
    position: absolute;
    top: 6px;
    right: 7px;
    color: #f59e0b;
    line-height: 1;
  }
  :global(.card-fav svg) { width: 11px; height: 11px; }

  /* State messages */
  .state-msg {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text-muted);
    font-size: .95rem;
    line-height: 1.7;
  }
  .state-msg.error { color: #dc2626; }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1rem;
    gap: .6rem;
  }
  .empty-icon { color: var(--color-border); }
  .empty-title { font-size: 1.05rem; font-weight: 600; color: var(--color-text); }
  .empty-sub { font-size: .85rem; color: var(--color-text-muted); max-width: 300px; line-height: 1.6; }

  .hidden { display: none !important; }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 1.5rem;
    text-align: center;
    font-size: .78rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  import { getHistory, addToHistory, clearHistory, isFavorite } from '@/lib/storage';
  import { search, preloadCommonChunks, type DictEntry } from '@/lib/searchService';
  import type { StoredEntry } from '@/lib/storage';

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const input          = document.getElementById('search-input')    as HTMLInputElement;
  const spinner        = document.getElementById('search-spinner')  as HTMLSpanElement;
  const clearBtn       = document.getElementById('search-clear')    as HTMLButtonElement;
  const searchSection  = document.getElementById('search-section')  as HTMLElement;
  const results        = document.getElementById('results')          as HTMLDivElement;
  const emptyEl        = document.getElementById('empty-state')     as HTMLDivElement;
  const errorEl        = document.getElementById('error-state')     as HTMLDivElement;
  const historySection = document.getElementById('history-section') as HTMLElement;
  const historyHeader  = document.getElementById('history-header')  as HTMLElement;
  const historyGrid    = document.getElementById('history-grid')    as HTMLDivElement;
  const historyEmpty   = document.getElementById('history-empty')   as HTMLDivElement;
  const clearHistBtn   = document.getElementById('clear-history-btn') as HTMLButtonElement;
  const resultsLabel   = document.getElementById('results-label')   as HTMLElement;

  // ── Filter tabs ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(t => {
        t.classList.remove('filter-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('filter-tab--active');
      tab.setAttribute('aria-selected', 'true');
    });
  });

  // ── State ─────────────────────────────────────────────────────────────────
  let debounceTimer: ReturnType<typeof setTimeout> | null = null;
  let lastQuery = '';
  let focusedIdx = -1;
  let currentResults: (DictEntry & { _score: number })[] = [];
  // Race-condition guard: every search invocation claims a unique ID.
  // If a newer search starts before this one finishes, its results are discarded.
  let searchGeneration = 0;

  // ── Language helpers ──────────────────────────────────────────────────────
  function getLang(): string {
    try { return localStorage.getItem('wz-lang') || 'vi'; }
    catch { return 'vi'; }
  }

  function getMeaning(e: DictEntry): string {
    const lang = getLang();
    if (lang === 'en') return e.meaning_en || e.vietnamese || '';
    return e.meaning_vi || e.meaning_en || e.vietnamese || '';
  }

  function updateCardMeanings() {
    const lang = getLang();
    document.querySelectorAll<HTMLElement>('[data-meaning-en]').forEach(card => {
      const meaning = lang === 'en'
        ? (card.dataset.meaningEn || card.dataset.meaningVi || '')
        : (card.dataset.meaningVi || card.dataset.meaningEn || '');
      const el = card.querySelector('.card-meaning');
      if (el) el.textContent = meaning;
    });
    const inp = document.getElementById('search-input') as HTMLInputElement;
    if (inp) inp.placeholder = lang === 'en'
      ? 'Enter Hanzi, pinyin or meaning...'
      : 'Nhập chữ Hán, pinyin hoặc nghĩa...';
  }

  window.addEventListener('wz:langchange', updateCardMeanings);

  // ── Card factory ─────────────────────────────────────────────────────────
  function makeCard(e: DictEntry, withFavBadge = true): HTMLAnchorElement {
    const showTrad = e.traditional && e.traditional !== e.simplified;
    const faved    = withFavBadge && isFavorite(e.id);
    const meaning  = getMeaning(e);

    const a = document.createElement('a');
    a.href  = `/word/${e.id}`;
    a.className = 'entry-card';
    a.setAttribute('role', 'listitem');
    a.dataset.meaningEn = e.meaning_en || e.vietnamese || '';
    a.dataset.meaningVi = e.meaning_vi || e.meaning_en || e.vietnamese || '';
    a.innerHTML = `
      <div class="card-accent">
        <span class="card-simplified">${e.simplified}</span>
        ${showTrad ? `<span class="card-traditional">${e.traditional}</span>` : ''}
      </div>
      <div class="card-body">
        <div class="card-meaning">${meaning}</div>
        ${e.pinyin ? `<div class="card-pinyin">${e.pinyin}</div>` : ''}
        ${e.hanviet ? `<div class="card-hanviet">${e.hanviet}</div>` : ''}
      </div>
      ${faved ? `<span class="card-fav" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      </span>` : ''}
    `;
    return a;
  }

  // ── Keyboard navigation ───────────────────────────────────────────────────
  function getCards(): HTMLAnchorElement[] {
    return Array.from(results.querySelectorAll<HTMLAnchorElement>('.entry-card'));
  }

  function setFocus(idx: number) {
    const cards = getCards();
    cards[focusedIdx]?.classList.remove('focused');
    focusedIdx = Math.max(-1, Math.min(idx, cards.length - 1));
    if (focusedIdx >= 0) {
      cards[focusedIdx].classList.add('focused');
      cards[focusedIdx].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  }

  input.addEventListener('keydown', (e) => {
    const cards = getCards();
    if (!cards.length) return;
    if (e.key === 'ArrowDown') { e.preventDefault(); setFocus(focusedIdx + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setFocus(focusedIdx <= 0 ? -1 : focusedIdx - 1); }
    else if (e.key === 'Enter' && focusedIdx >= 0) { e.preventDefault(); cards[focusedIdx].click(); }
    else if (e.key === 'Escape') { setFocus(-1); }
  });

  // ── Loading state ─────────────────────────────────────────────────────────
  function setLoading(on: boolean) {
    spinner.classList.toggle('active', on);
  }

  // ── UI: show/hide sections ─────────────────────────────────────────────────
  function showSearchUI() {
    searchSection.classList.remove('hidden');
    historySection.style.display = 'none';
  }
  function showHistoryUI() {
    searchSection.classList.add('hidden');
    historySection.style.display = '';
    renderHistory();
  }

  // ── Clear button ──────────────────────────────────────────────────────────
  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.hidden = true;
    doSearch('');
    input.focus();
  });

  // ── Lịch sử ──────────────────────────────────────────────────────────────
  function renderHistory() {
    historyGrid.innerHTML = '';
    const h = getHistory();
    if (h.length === 0) {
      historyHeader.style.display = 'none';
      historyEmpty.classList.remove('hidden');
    } else {
      historyHeader.style.display = '';
      historyEmpty.classList.add('hidden');
      h.forEach(e => historyGrid.appendChild(makeCard(e as unknown as DictEntry)));
    }
  }

  clearHistBtn.addEventListener('click', () => {
    clearHistory();
    renderHistory();
  });

  // ── Tìm kiếm ─────────────────────────────────────────────────────────────
  async function doSearch(q: string) {
    if (q === lastQuery) return;
    lastQuery = q;
    focusedIdx = -1;

    if (!q.trim()) {
      // Bump generation so any in-flight request is silently dropped
      searchGeneration++;
      results.innerHTML = '';
      currentResults = [];
      showHistoryUI();
      setLoading(false);
      return;
    }

    // Claim this generation; save it locally so the closure can check it later
    const myGen = ++searchGeneration;

    showSearchUI();
    emptyEl.classList.add('hidden');
    errorEl.classList.add('hidden');
    setLoading(true);

    try {
      const data = await search(q);

      // Another search started after this one — throw away these stale results
      if (myGen !== searchGeneration) return;

      currentResults = data;
      results.innerHTML = '';

      const lang = getLang();
      if (resultsLabel) {
        resultsLabel.textContent = lang === 'en'
          ? `${data.length} results for "${q}"`
          : `${data.length} kết quả cho "${q}"`;
      }

      if (data.length === 0) {
        emptyEl.innerHTML = lang === 'en'
          ? `No results for <strong>"${q}"</strong>`
          : `Không tìm thấy kết quả cho <strong>"${q}"</strong>`;
        emptyEl.classList.remove('hidden');
      } else {
        data.forEach(e => results.appendChild(makeCard(e)));
      }
    } catch (err) {
      if (myGen !== searchGeneration) return;
      console.error('Search error:', err);
      results.innerHTML = '';
      errorEl.textContent = 'Lỗi tìm kiếm. Vui lòng thử lại.';
      errorEl.classList.remove('hidden');
    } finally {
      // Only stop the spinner if we are still the active search
      if (myGen === searchGeneration) setLoading(false);
    }
  }

  // ── Input events ──────────────────────────────────────────────────────────
  input.addEventListener('input', () => {
    const q = input.value;
    clearBtn.hidden = !q;
    if (debounceTimer) clearTimeout(debounceTimer);

    if (!q.trim()) {
      // Clear immediately — no debounce needed, and bump gen to cancel in-flight
      lastQuery = '';
      searchGeneration++;
      results.innerHTML = '';
      currentResults = [];
      setLoading(false);
      showHistoryUI();
      return;
    }

    debounceTimer = setTimeout(() => doSearch(q), 300);
  });

  // ── Init ─────────────────────────────────────────────────────────────────
  preloadCommonChunks().catch(() => {});
  showHistoryUI();
  input.focus();
</script>
