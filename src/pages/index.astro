---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';

export const prerender = true;
---

<BaseLayout>
  <div class="page">

    <!-- ── Header ── -->
    <header class="header">
      <div class="header-inner container">
        <a href="/" class="brand" aria-label="WenZi — Trang chủ">
          <img src="/favicon.png" alt="" width="28" height="28" />
          <span class="brand-name">WenZi</span>
          <span class="brand-han" aria-hidden="true">文字</span>
        </a>
        <ThemeToggle />
      </div>
    </header>

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="logo-wrap" aria-hidden="true">
          <img src="/favicon.png" alt="WenZi logo" width="88" height="88" class="logo" />
        </div>
        <h1 class="app-name">
          WenZi
          <span class="app-name-han" lang="zh">文字</span>
        </h1>
        <p class="app-desc">Từ điển Hán Việt đơn giản và hiệu quả.</p>

        <!-- Search -->
        <div class="search-area">
          <div class="search-wrapper" id="search-wrapper">
            <span class="search-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.35-4.35"/>
              </svg>
            </span>
            <input
              type="search"
              id="search-input"
              class="search-input"
              placeholder="Nhập chữ Hán, pinyin hoặc nghĩa..."
              autocomplete="off"
              spellcheck="false"
              aria-label="Tìm kiếm từ vựng"
              aria-controls="results"
              aria-autocomplete="list"
            />
            <span class="search-spinner" id="search-spinner" aria-hidden="true"></span>
            <kbd class="search-hint" id="search-hint" aria-hidden="true">↵</kbd>
          </div>
          <p class="search-caption">
            Tìm theo chữ Hán <span class="sep">·</span> pinyin <span class="sep">·</span> Hán Việt <span class="sep">·</span> nghĩa tiếng Việt
          </p>
        </div>
      </div>
    </section>

    <!-- ── Results ── -->
    <main class="results-section container" id="results-section" aria-live="polite">
      <div id="results" class="results-grid" role="list"></div>
      <div id="empty-state"  class="state-msg hidden"></div>
      <div id="error-state"  class="state-msg error hidden"></div>
    </main>

    <!-- ── Footer ── -->
    <footer class="footer">
      <div class="container">
        <p>WenZi © 2026 &mdash; MIT License</p>
      </div>
    </footer>
  </div>
</BaseLayout>

<!-- ═══════════════════════ Styles ═══════════════════════ -->
<style>
  .page { display: flex; flex-direction: column; min-height: 100dvh; }

  .container {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* Header */
  .header {
    border-bottom: 1px solid var(--color-border);
    position: sticky; top: 0; z-index: 10;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
  }
  .header-inner {
    display: flex; align-items: center;
    justify-content: space-between; height: 56px;
  }
  .brand {
    display: flex; align-items: center; gap: 8px;
    text-decoration: none; color: var(--color-text);
  }
  .brand img { border-radius: 6px; }
  .brand-name { font-weight: 700; font-size: 1.05rem; letter-spacing: -.01em; }
  .brand-han  { font-size: .9rem; color: var(--color-text-muted); }

  /* Hero */
  .hero { padding: 3rem 0 2rem; }
  .hero-inner {
    display: flex; flex-direction: column;
    align-items: center; text-align: center; gap: 1.1rem;
  }
  .logo { border-radius: 20px; box-shadow: var(--shadow-md); }
  .app-name {
    font-size: clamp(2.2rem, 7vw, 3.2rem);
    font-weight: 800; letter-spacing: -.04em; line-height: 1;
    display: flex; align-items: baseline; gap: .35em;
  }
  .app-name-han { font-size: .52em; font-weight: 400; color: var(--color-text-muted); }
  .app-desc { font-size: 1rem; color: var(--color-text-muted); max-width: 320px; }

  /* Search */
  .search-area { width: 100%; max-width: 560px; margin: .4rem auto 0; }
  .search-wrapper {
    position: relative; display: flex; align-items: center;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 999px;
    box-shadow: var(--shadow-md);
    transition: border-color .2s, box-shadow .2s;
    overflow: hidden;
  }
  .search-wrapper:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent), var(--shadow-md);
  }
  .search-icon {
    display: flex; align-items: center;
    padding: 0 12px 0 18px;
    color: var(--color-text-muted);
    pointer-events: none; flex-shrink: 0;
  }
  .search-input {
    flex: 1; border: none; outline: none;
    background: transparent; color: var(--color-text);
    font-size: 1rem; font-family: var(--font-sans);
    padding: 15px 0; min-width: 0;
  }
  .search-input::placeholder { color: var(--color-text-muted); opacity: .7; }
  .search-input::-webkit-search-cancel-button { display: none; }

  /* Spinner */
  .search-spinner {
    display: none; width: 18px; height: 18px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%; margin-right: 14px; flex-shrink: 0;
  }
  .search-spinner.active {
    display: block;
    animation: spin .7s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .search-hint {
    display: flex; align-items: center; justify-content: center;
    margin-right: 14px; padding: 3px 7px;
    border: 1px solid var(--color-border);
    border-radius: 6px; background: var(--color-bg);
    color: var(--color-text-muted);
    font-family: var(--font-mono); font-size: .78rem;
    flex-shrink: 0; transition: opacity .2s;
  }
  .search-wrapper:focus-within .search-hint { opacity: 0; pointer-events: none; }

  .search-caption {
    margin-top: 9px; text-align: center;
    font-size: .78rem; color: var(--color-text-muted);
  }
  .sep { margin: 0 4px; opacity: .4; }

  /* Results */
  .results-section {
    flex: 1;
    padding-top: 1.75rem;
    padding-bottom: 3rem;
  }
  .results-grid {
    display: grid;
    gap: .75rem;
    grid-template-columns: 1fr;
  }

  /* Card (rendered by JS) */
  :global(.entry-card) {
    display: flex; align-items: stretch;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: box-shadow .15s, transform .15s;
    animation: fadeIn .18s ease;
  }
  :global(.entry-card:hover) {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; } }

  :global(.card-accent) {
    background: var(--color-primary);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 1.1rem 1.25rem;
    min-width: 88px; gap: .2rem;
  }
  :global(.card-simplified) {
    font-size: 2.2rem; line-height: 1;
    color: #fff; font-weight: 400;
  }
  :global(.card-traditional) {
    font-size: .75rem; color: rgba(255,255,255,.65);
  }

  :global(.card-body) {
    flex: 1; padding: .9rem 1.1rem;
    display: flex; flex-direction: column; gap: .3rem;
    justify-content: center;
  }
  :global(.card-vietnamese) {
    font-size: 1.05rem; font-weight: 600;
    color: var(--color-text);
  }
  :global(.card-pinyin) {
    font-size: .88rem; font-style: italic;
    color: var(--color-primary); opacity: .9;
  }

  /* State messages */
  .state-msg {
    text-align: center; padding: 2.5rem 1rem;
    color: var(--color-text-muted); font-size: .95rem;
    line-height: 1.7;
  }
  .state-msg.error { color: var(--color-primary); }
  .hidden { display: none !important; }

  /* Responsive */
  @media (min-width: 560px) {
    .results-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 760px) {
    .results-grid { grid-template-columns: repeat(3, 1fr); }
    :global(.card-accent) { min-width: 80px; }
  }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0; text-align: center;
    font-size: .8rem; color: var(--color-text-muted);
  }
</style>

<!-- ═══════════════════════ Client Script ═══════════════════════ -->
<script>
  const input    = document.getElementById('search-input')    as HTMLInputElement;
  const results  = document.getElementById('results')         as HTMLDivElement;
  const spinner  = document.getElementById('search-spinner')  as HTMLSpanElement;
  const hint     = document.getElementById('search-hint')     as HTMLElement;
  const empty    = document.getElementById('empty-state')     as HTMLDivElement;
  const errorEl  = document.getElementById('error-state')     as HTMLDivElement;

  let debounceTimer: ReturnType<typeof setTimeout> | null = null;
  let lastQuery = '';

  function setLoading(on: boolean) {
    spinner.classList.toggle('active', on);
    hint.style.display = on ? 'none' : '';
  }

  function hideStates() {
    empty.classList.add('hidden');
    errorEl.classList.add('hidden');
  }

  function renderCards(entries: {
    simplified: string;
    traditional: string | null;
    pinyin: string | null;
    vietnamese: string;
  }[]) {
    results.innerHTML = '';
    entries.forEach(e => {
      const showTraditional = e.traditional && e.traditional !== e.simplified;

      const card = document.createElement('div');
      card.className = 'entry-card';
      card.setAttribute('role', 'listitem');
      card.innerHTML = `
        <div class="card-accent">
          <span class="card-simplified">${e.simplified}</span>
          ${showTraditional ? `<span class="card-traditional">${e.traditional}</span>` : ''}
        </div>
        <div class="card-body">
          <div class="card-vietnamese">${e.vietnamese}</div>
          ${e.pinyin ? `<div class="card-pinyin">${e.pinyin}</div>` : ''}
        </div>
      `;
      results.appendChild(card);
    });
  }

  async function doSearch(q: string) {
    if (q === lastQuery) return;
    lastQuery = q;

    hideStates();

    if (q.trim() === '') {
      results.innerHTML = '';
      setLoading(false);
      return;
    }

    setLoading(true);

    try {
      const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json();

      if (data.error) {
        results.innerHTML = '';
        errorEl.textContent = data.error;
        errorEl.classList.remove('hidden');
        return;
      }

      if (data.length === 0) {
        results.innerHTML = '';
        empty.innerHTML = `Không tìm thấy kết quả cho <strong>"${q}"</strong>`;
        empty.classList.remove('hidden');
      } else {
        renderCards(data);
      }
    } catch {
      results.innerHTML = '';
      errorEl.textContent = 'Không thể kết nối đến máy chủ. Vui lòng thử lại.';
      errorEl.classList.remove('hidden');
    } finally {
      setLoading(false);
    }
  }

  input.addEventListener('input', () => {
    if (debounceTimer) clearTimeout(debounceTimer);
    const q = input.value;

    if (q.trim() === '') {
      // Xóa ngay lập tức khi input rỗng
      if (debounceTimer) clearTimeout(debounceTimer);
      doSearch('');
      return;
    }

    debounceTimer = setTimeout(() => doSearch(q), 300);
  });
</script>
