---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Trợ giúp">
  <div class="container mx-auto p-6">
    <h1 class="text-4xl font-bold mb-4">Trang Trợ giúp</h1>
    <p class="text-lg">Nội dung hướng dẫn sẽ được thêm vào đây sớm.</p>
    
    <div class="mt-8">
      <h2 class="text-2xl font-semibold mb-3">Các chủ đề thường gặp</h2>
      <ul class="list-disc list-inside space-y-2">
        <li><a href="#" class="text-blue-400 hover:underline">Cách sử dụng từ điển</a></li>
        <li><a href="#" class="text-blue-400 hover:underline">Quản lý sổ tay</a></li>
        <li><a href="#" class="text-blue-400 hover:underline">Tùy chỉnh lộ trình học</a></li>
      </ul>
    </div>
  </div>
</BaseLayout>
