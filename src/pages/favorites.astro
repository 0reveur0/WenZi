---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';

export const prerender = true;
---

<BaseLayout title="Yêu thích — WenZi">
  <div class="page">
    <Header activePage="favorites" />

    <main class="fav-main">
      <div class="container">

        <div class="page-hdr">
          <h1 class="page-title">
            <span class="title-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="currentColor" stroke="currentColor" stroke-width="1.5">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </span>
            Từ yêu thích
          </h1>
          <button class="btn-clear" id="clear-btn" type="button" hidden>Xóa tất cả</button>
        </div>

        <div id="fav-grid" class="results-grid"></div>

        <div id="fav-empty" class="empty-state">
          <div class="empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <p class="empty-title">Chưa có từ yêu thích</p>
          <p class="empty-sub">
            Nhấn vào biểu tượng ★ trên trang chi tiết để lưu từ vào đây.
          </p>
          <a href="/" class="btn-home">Tìm từ ngay</a>
        </div>

      </div>
    </main>

    <footer class="footer">
      <p>WenZi © 2026 &mdash; MIT License</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; min-height: 100dvh; }

  .fav-main { flex: 1; padding: 2rem 1.5rem 4rem; }

  .container { max-width: 1120px; margin: 0 auto; }

  .page-hdr {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }
  .page-title {
    display: flex;
    align-items: center;
    gap: .6rem;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -.02em;
    color: var(--color-text);
  }
  .title-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    background: #fef3c7;
    color: #f59e0b;
    border-radius: 10px;
  }

  .btn-clear {
    background: none;
    border: 1.5px solid var(--color-border);
    color: var(--color-text-muted);
    border-radius: 8px;
    padding: .4rem .9rem;
    font-size: .82rem;
    cursor: pointer;
    transition: all .15s;
  }
  .btn-clear:hover { border-color: #dc2626; color: #dc2626; }

  /* Results grid */
  .results-grid { display: grid; gap: .75rem; grid-template-columns: 1fr; }
  @media (min-width: 560px) { .results-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 820px) { .results-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1080px) { .results-grid { grid-template-columns: repeat(4, 1fr); } }

  /* Cards */
  :global(.entry-card) {
    display: flex; align-items: stretch;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: box-shadow .15s, transform .15s;
    animation: fadeIn .18s ease;
  }
  :global(.entry-card:hover) {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    text-decoration: none;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  :global(.card-accent) {
    background: var(--color-primary);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 1rem .9rem; min-width: 70px; gap: .2rem;
  }
  :global(.card-simplified) { font-size: 1.9rem; color: #fff; line-height: 1; font-weight: 400; }
  :global(.card-traditional) { font-size: .65rem; color: rgba(255,255,255,.65); }
  :global(.card-body) {
    flex: 1; padding: .75rem .9rem;
    display: flex; flex-direction: column; gap: .2rem; justify-content: center; min-width: 0;
  }
  :global(.card-vietnamese) {
    font-size: .92rem; font-weight: 600; color: var(--color-text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  :global(.card-pinyin) { font-size: .8rem; font-style: italic; color: var(--color-primary); }
  :global(.card-hanviet) {
    font-size: .75rem; color: var(--color-text-muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* Empty state */
  .empty-state {
    display: flex; flex-direction: column;
    align-items: center; text-align: center;
    padding: 5rem 1rem; gap: .8rem;
  }
  .empty-icon { color: var(--color-border); }
  .empty-title { font-size: 1.2rem; font-weight: 700; color: var(--color-text); }
  .empty-sub { font-size: .88rem; color: var(--color-text-muted); max-width: 300px; line-height: 1.6; }
  .btn-home {
    margin-top: .5rem;
    background: var(--color-primary);
    color: #fff;
    padding: .65rem 1.6rem;
    border-radius: 999px;
    font-size: .9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background .15s;
  }
  .btn-home:hover { background: var(--color-primary-hover); text-decoration: none; }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 1.5rem;
    text-align: center;
    font-size: .78rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  import { getFavorites, clearFavorites } from '@/lib/storage';
  import type { StoredEntry } from '@/lib/storage';

  const grid     = document.getElementById('fav-grid')!;
  const emptyEl  = document.getElementById('fav-empty')!;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  function makeCard(e: StoredEntry): HTMLAnchorElement {
    const showTrad = e.traditional && e.traditional !== e.simplified;
    const a = document.createElement('a');
    a.href = `/word/${e.id}`;
    a.className = 'entry-card';
    a.innerHTML = `
      <div class="card-accent">
        <span class="card-simplified">${e.simplified}</span>
        ${showTrad ? `<span class="card-traditional">${e.traditional}</span>` : ''}
      </div>
      <div class="card-body">
        <div class="card-vietnamese">${e.vietnamese}</div>
        ${e.pinyin ? `<div class="card-pinyin">${e.pinyin}</div>` : ''}
        ${e.hanviet ? `<div class="card-hanviet">${e.hanviet}</div>` : ''}
      </div>`;
    return a;
  }

  function render() {
    const favs = getFavorites();
    grid.innerHTML = '';
    if (favs.length === 0) {
      emptyEl.style.display = '';
      clearBtn.hidden = true;
    } else {
      emptyEl.style.display = 'none';
      clearBtn.hidden = false;
      favs.forEach(e => grid.appendChild(makeCard(e)));
    }
  }

  clearBtn.addEventListener('click', () => {
    if (confirm('Xóa toàn bộ danh sách yêu thích?')) {
      clearFavorites();
      render();
    }
  });

  render();
</script>
