---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import sampleData from '@/data/sample_dictionary.json';

// Pre-generate static pages for all entries in sample data
// In production with larger datasets, you'd limit this or use client-side only
export function getStaticPaths() {
  return sampleData.map((entry, index) => ({
    params: { id: String(index) },
    props: {
      id: index,
      simplified: entry.simplified,
      traditional: entry.traditional,
      pinyin: entry.pinyin,
      hanviet: entry.hanviet,
      vietnamese: entry.vietnamese
    }
  }));
}

const { id, simplified, traditional, pinyin, hanviet, vietnamese } = Astro.props;
const showTraditional = traditional && traditional !== simplified;
const pageTitle = `${simplified} — WenZi`;
---

<BaseLayout title={pageTitle}>
  <div class="page">
    <Header backHref="/" />

    <main class="detail container">

      <!-- Chữ lớn + phiên âm -->
      <section class="char-section">
        <div class="char-display">
          <span class="char-main" lang="zh">{simplified}</span>
          {showTraditional && (
            <span class="char-trad" lang="zh" title="Phồn thể">{traditional}</span>
          )}
        </div>

        {pinyin && (
          <p class="pinyin">{pinyin}</p>
        )}

        {hanviet && (
          <p class="hanviet">Hán Việt: {hanviet}</p>
        )}
      </section>

      <!-- Nghĩa -->
      <section class="meaning-section">
        <span class="label">Nghĩa tiếng Việt</span>
        <p class="meaning">{vietnamese}</p>
      </section>

      <!-- Hành động -->
      <div class="actions">
        <button class="btn btn-speak" id="speak-btn" type="button" aria-label="Phát âm">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
            <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
          </svg>
          <span id="speak-label">Phát âm</span>
        </button>

        <button class="btn btn-fav" id="fav-btn" type="button" aria-label="Yêu thích">
          <svg id="fav-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          <span id="fav-label">Yêu thích</span>
        </button>
      </div>

      <!-- Dữ liệu truyền sang client -->
      <div id="entry-data"
        data-id={id}
        data-simplified={simplified}
        data-traditional={traditional ?? ''}
        data-pinyin={pinyin ?? ''}
        data-hanviet={hanviet ?? ''}
        data-vietnamese={vietnamese}
        hidden
      ></div>

    </main>

    <footer class="footer">
      <div class="container">
        <p>WenZi © 2026 &mdash; MIT License</p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; min-height: 100dvh; }

  .container {
    max-width: 680px; margin: 0 auto;
    padding: 0 1.25rem; width: 100%;
  }

  /* Detail layout */
  .detail {
    flex: 1;
    display: flex; flex-direction: column;
    gap: 2rem;
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  /* Chữ lớn */
  .char-section {
    display: flex; flex-direction: column;
    align-items: center; text-align: center;
    gap: .75rem;
  }

  .char-display {
    display: flex; align-items: flex-end; gap: 1.25rem;
    flex-wrap: wrap; justify-content: center;
  }

  .char-main {
    font-size: clamp(5rem, 20vw, 9rem);
    line-height: 1;
    color: var(--color-primary);
    font-weight: 300;
    letter-spacing: -.02em;
    text-shadow: 0 2px 16px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .char-trad {
    font-size: clamp(1.6rem, 6vw, 2.4rem);
    color: var(--color-text-muted);
    font-weight: 300;
    padding-bottom: .5rem;
  }
  .char-trad::before {
    content: '(';
    color: var(--color-border);
    margin-right: .1em;
  }
  .char-trad::after {
    content: ')';
    color: var(--color-border);
    margin-left: .1em;
  }

  .pinyin {
    font-size: 1.5rem;
    font-style: italic;
    color: var(--color-text-muted);
    letter-spacing: .02em;
  }

  .hanviet {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  /* Nghĩa */
  .meaning-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    display: flex; flex-direction: column; gap: .4rem;
  }

  .label {
    font-size: .72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .07em;
    color: var(--color-text-muted);
  }

  .meaning {
    font-size: 1.3rem; font-weight: 600;
    color: var(--color-text); line-height: 1.4;
  }

  /* Buttons */
  .actions {
    display: flex; gap: .75rem; flex-wrap: wrap;
  }

  .btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: .65rem 1.2rem;
    border-radius: var(--radius-sm);
    font-size: .9rem; font-weight: 500;
    cursor: pointer;
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    transition: all .15s;
  }
  .btn:hover { border-color: var(--color-primary); color: var(--color-primary); background: var(--color-primary-dim); }
  .btn:active { transform: scale(.97); }

  .btn-fav.active {
    background: color-mix(in srgb, var(--color-primary) 12%, var(--color-surface));
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .btn-fav.active #fav-icon { fill: var(--color-primary); }

  .btn-speak.speaking {
    border-color: var(--color-primary);
    color: var(--color-primary);
    animation: pulse 1s ease infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .6; } }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0; text-align: center;
    font-size: .8rem; color: var(--color-text-muted);
  }
</style>

<script>
  import { addToHistory, isFavorite, toggleFavorite } from '@/lib/storage';
  import type { StoredEntry } from '@/lib/storage';

  // ── Đọc dữ liệu từ DOM ──────────────────────────────────────────────────
  const el  = document.getElementById('entry-data')!;
  const entry: StoredEntry = {
    id:          Number(el.dataset.id),
    simplified:  el.dataset.simplified!,
    traditional: el.dataset.traditional || null,
    pinyin:      el.dataset.pinyin      || null,
    hanviet:     el.dataset.hanviet     || null,
    vietnamese:  el.dataset.vietnamese!,
  };

  // ── Lưu lịch sử ─────────────────────────────────────────────────────────
  addToHistory(entry);

  // ── Nút yêu thích ───────────────────────────────────────────────────────
  const favBtn   = document.getElementById('fav-btn')!;
  const favLabel = document.getElementById('fav-label')!;
  const favIcon  = document.getElementById('fav-icon')!;

  function updateFavUI(active: boolean) {
    favBtn.classList.toggle('active', active);
    favLabel.textContent = active ? 'Đã lưu' : 'Yêu thích';
    favIcon.setAttribute('fill', active ? 'currentColor' : 'none');
  }

  updateFavUI(isFavorite(entry.id));

  favBtn.addEventListener('click', () => {
    const nowFaved = toggleFavorite(entry);
    updateFavUI(nowFaved);
  });

  // ── Phát âm (Web Speech API) ─────────────────────────────────────────────
  const speakBtn   = document.getElementById('speak-btn')!;
  const speakLabel = document.getElementById('speak-label')!;

  function speak(text: string) {
    if (!('speechSynthesis' in window)) {
      alert('Trình duyệt của bạn không hỗ trợ tính năng phát âm.');
      return;
    }

    window.speechSynthesis.cancel();

    const utt  = new SpeechSynthesisUtterance(text);
    utt.lang   = 'zh-CN';
    utt.rate   = 0.85;
    utt.pitch  = 1;

    speakBtn.classList.add('speaking');
    speakLabel.textContent = 'Đang phát...';

    utt.onend = utt.onerror = () => {
      speakBtn.classList.remove('speaking');
      speakLabel.textContent = 'Phát âm';
    };

    window.speechSynthesis.speak(utt);
  }

  speakBtn.addEventListener('click', () => speak(entry.simplified));
</script>
