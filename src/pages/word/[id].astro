---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import StrokeOrder from '@/components/StrokeOrder.astro';
import sampleData from '@/data/sample_dictionary.json';

export function getStaticPaths() {
  return sampleData.map((entry, index) => ({
    params: { id: String(index) },
    props: {
      id: index,
      simplified: entry.simplified,
      traditional: entry.traditional,
      pinyin: entry.pinyin,
      hanviet: entry.hanviet,
      meaning_vi: entry.meaning_vi || entry.vietnamese || '',
      meaning_en: entry.meaning_en || '',
      vietnamese: entry.vietnamese || '',
    }
  }));
}

const { id, simplified, traditional, pinyin, hanviet, meaning_vi, meaning_en, vietnamese } = Astro.props;
const showTraditional = traditional && traditional !== simplified;
const pageTitle = `${simplified} — WenZi`;
---

<BaseLayout title={pageTitle}>
  <div class="page">
    <Header backHref="/" />

    <main class="detail">
      <div class="container">

        <!-- Character card -->
        <div class="char-card">
          <div class="char-card-inner">
            <div class="char-display">
              <span class="char-main" lang="zh">{simplified}</span>
              {showTraditional && (
                <div class="char-trad-wrap">
                  <span class="char-trad-label" data-i18n="traditional">Phồn thể</span>
                  <span class="char-trad" lang="zh">{traditional}</span>
                </div>
              )}
            </div>
            <div class="char-meta">
              {pinyin && <p class="char-pinyin">{pinyin}</p>}
              {hanviet && <p class="char-hanviet">Hán Việt: <strong>{hanviet}</strong></p>}
            </div>
          </div>
        </div>

        <!-- Bilingual meaning card -->
        <div class="meaning-card">
          <div class="meaning-row" id="meaning-vi" data-lang-row="vi">
            <div class="meaning-lang-tag">
              <span class="flag">🇻🇳</span>
              <span class="lang-name" data-i18n="meaningViLabel">Tiếng Việt</span>
            </div>
            <p class="meaning-text" id="meaning-vi-text">{meaning_vi || '—'}</p>
          </div>
          <div class="meaning-divider"></div>
          <div class="meaning-row" id="meaning-en" data-lang-row="en">
            <div class="meaning-lang-tag">
              <span class="flag">🇬🇧</span>
              <span class="lang-name" data-i18n="meaningEnLabel">Tiếng Anh</span>
            </div>
            <p class="meaning-text" id="meaning-en-text">{meaning_en || '—'}</p>
          </div>
        </div>

        <!-- Example sentences -->
        <div class="examples-card" id="examples-section" style="display:none">
          <div class="examples-header">
            <span class="examples-label" data-i18n="examples">Ví dụ câu</span>
          </div>
          <div class="examples-list" id="examples-list"></div>
        </div>

        <!-- Stroke order animation -->
        <StrokeOrder simplified={simplified} />

        <!-- Actions -->
        <div class="actions">
          <button class="action-btn" id="speak-btn" type="button" aria-label="Phát âm">
            <span class="action-btn-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
              </svg>
            </span>
            <span id="speak-label" data-i18n="pronounce">Phát âm</span>
          </button>

          <button class="action-btn action-btn--fav" id="fav-btn" type="button" aria-label="Yêu thích">
            <span class="action-btn-icon">
              <svg id="fav-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </span>
            <span id="fav-label" data-i18n="favorite">Yêu thích</span>
          </button>
        </div>

        <!-- Info pills -->
        <div class="info-pills">
          {pinyin && (
            <div class="pill">
              <span class="pill-label" data-i18n="pinyin">Pinyin</span>
              <span class="pill-value">{pinyin}</span>
            </div>
          )}
          {hanviet && (
            <div class="pill">
              <span class="pill-label" data-i18n="hanviet">Hán Việt</span>
              <span class="pill-value">{hanviet}</span>
            </div>
          )}
          {showTraditional && (
            <div class="pill">
              <span class="pill-label" data-i18n="traditional">Phồn thể</span>
              <span class="pill-value" lang="zh">{traditional}</span>
            </div>
          )}
          <div class="pill">
            <span class="pill-label" data-i18n="simplified">Giản thể</span>
            <span class="pill-value" lang="zh">{simplified}</span>
          </div>
        </div>

      </div>
    </main>

    <footer class="footer">
      <p>WenZi © 2026 &mdash; MIT License</p>
    </footer>
  </div>

  <!-- Data bridge for client script -->
  <div id="entry-data"
    data-id={id}
    data-simplified={simplified}
    data-traditional={traditional ?? ''}
    data-pinyin={pinyin ?? ''}
    data-hanviet={hanviet ?? ''}
    data-meaning-vi={meaning_vi ?? ''}
    data-meaning-en={meaning_en ?? ''}
    data-vietnamese={vietnamese}
    hidden
  ></div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; min-height: 100dvh; }

  .detail { flex: 1; padding: 2rem 1.25rem 5rem; }
  @media (min-width: 640px) { .detail { padding: 2.5rem 2rem 5rem; } }

  .container {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Character card ────────────────────────────────────────────────── */
  .char-card {
    background: var(--color-primary);
    border-radius: var(--radius-xl);
    padding: 3rem 2rem 2.5rem;
    box-shadow: 0 12px 48px color-mix(in srgb, var(--color-primary) 45%, transparent);
  }
  .char-card-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }
  .char-display {
    display: flex;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .char-main {
    font-size: clamp(5rem, 22vw, 9rem);
    line-height: 1;
    color: #fff;
    font-weight: 300;
    letter-spacing: -.02em;
    text-shadow: 0 6px 32px rgba(0,0,0,.25);
  }
  .char-trad-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .3rem;
    padding-bottom: .85rem;
  }
  .char-trad-label {
    font-size: .65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.5);
  }
  .char-trad {
    font-size: clamp(1.75rem, 6vw, 2.75rem);
    color: rgba(255,255,255,.8);
    font-weight: 300;
  }
  .char-meta { display: flex; flex-direction: column; gap: .5rem; }
  .char-pinyin {
    font-size: 1.6rem;
    font-style: italic;
    color: rgba(255,255,255,.95);
    letter-spacing: .04em;
    font-weight: 400;
  }
  .char-hanviet {
    font-size: 1.05rem;
    color: rgba(255,255,255,.7);
    line-height: var(--lh-normal);
  }
  .char-hanviet strong { color: rgba(255,255,255,.95); font-weight: 700; }

  /* ── Bilingual meaning card ────────────────────────────────────────── */
  .meaning-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .meaning-row {
    padding: 1.4rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    transition: background .2s;
  }
  .meaning-row.active { background: var(--color-primary-dim); }
  .meaning-divider {
    height: 1px;
    background: var(--color-border);
    margin: 0 1.25rem;
  }
  .meaning-lang-tag {
    display: flex;
    align-items: center;
    gap: .45rem;
  }
  .flag { font-size: 1rem; line-height: 1; }
  .lang-name {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--color-text-muted);
  }
  .meaning-row.active .lang-name { color: var(--color-primary); }
  .meaning-text {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: var(--lh-relaxed);
  }
  .meaning-row.active .meaning-text { color: var(--color-primary); }

  /* ── Examples card ─────────────────────────────────────────────────── */
  .examples-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 1.5rem 1.75rem;
  }
  .examples-header { margin-bottom: 1.1rem; }
  .examples-label {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .09em;
    color: var(--color-text-muted);
  }
  .examples-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  :global(.example-item) {
    border-left: 3px solid var(--color-primary);
    padding: .85rem 1.1rem;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: var(--color-bg);
  }
  :global([data-theme='dark'] .example-item) { background: rgba(255,255,255,.04); }
  :global(.example-cn) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: .4rem;
    line-height: var(--lh-normal);
  }
  :global(.example-en) {
    font-size: .95rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: var(--lh-relaxed);
  }
  :global(.example-vi) {
    font-size: .95rem;
    color: var(--color-primary);
    line-height: var(--lh-relaxed);
    margin-top: .25rem;
    font-weight: 500;
  }

  /* ── Actions ────────────────────────────────────────────────────────── */
  .actions { display: flex; gap: .85rem; flex-wrap: wrap; }
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: .75rem 1.4rem;
    border-radius: var(--radius-md);
    font-size: .95rem;
    font-weight: 600;
    cursor: pointer;
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    box-shadow: var(--shadow-sm);
    transition: all .15s;
  }
  .action-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-dim);
  }
  .action-btn:active { transform: scale(.97); }
  .action-btn-icon { display: flex; align-items: center; }

  .action-btn--fav.active {
    background: #fef3c7;
    border-color: #f59e0b;
    color: #d97706;
  }
  .action-btn--fav.active #fav-icon { fill: #f59e0b; stroke: #f59e0b; }

  .action-btn.speaking {
    border-color: var(--color-primary);
    color: var(--color-primary);
    animation: pulse 1s ease infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .55; } }

  /* ── Info pills ─────────────────────────────────────────────────────── */
  .info-pills {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }
  .pill {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    padding: .8rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    min-width: 100px;
  }
  .pill-label {
    font-size: .68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--color-text-muted);
  }
  .pill-value {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: .01em;
    line-height: 1.3;
  }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: center;
    font-size: .82rem;
    color: var(--color-text-muted);
  }
</style>

<script>
  import { addToHistory, isFavorite, toggleFavorite } from '@/lib/storage';
  import type { StoredEntry } from '@/lib/storage';
  import { getExamples } from '@/lib/examples';
  import { UI } from '@/lib/i18n';
  import type { Lang } from '@/lib/i18n';

  const el = document.getElementById('entry-data')!;
  const simplified = el.dataset.simplified!;

  const entry: StoredEntry = {
    id:          Number(el.dataset.id),
    simplified,
    traditional: el.dataset.traditional || null,
    pinyin:      el.dataset.pinyin      || null,
    hanviet:     el.dataset.hanviet     || null,
    meaning_vi:  el.dataset.meaningVi   || '',
    meaning_en:  el.dataset.meaningEn   || '',
    vietnamese:  el.dataset.vietnamese  || '',
  };

  addToHistory(entry);

  // ── Language state ─────────────────────────────────────────────────────────
  function getLang(): Lang {
    try { return (localStorage.getItem('wz-lang') as Lang) || 'vi'; }
    catch { return 'vi'; }
  }

  function applyLang(lang: Lang) {
    const viRow = document.getElementById('meaning-vi');
    const enRow = document.getElementById('meaning-en');
    viRow?.classList.toggle('active', lang === 'vi');
    enRow?.classList.toggle('active', lang === 'en');

    const ui = UI[lang];

    const speakLabel = document.getElementById('speak-label');
    if (speakLabel) speakLabel.textContent = ui.pronounce;
    const favLabel = document.getElementById('fav-label');
    if (favLabel) {
      favLabel.textContent = isFavorite(entry.id) ? ui.favorited : ui.favorite;
    }

    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.dataset.i18n as keyof typeof ui;
      const val = ui[key];
      if (typeof val === 'string') el.textContent = val;
    });

    renderExamples(lang);
  }

  // ── Examples ──────────────────────────────────────────────────────────────
  function renderExamples(lang: Lang) {
    const section = document.getElementById('examples-section')!;
    const list = document.getElementById('examples-list')!;
    const examples = getExamples(simplified);

    if (examples.length === 0) {
      section.style.display = 'none';
      return;
    }

    section.style.display = '';
    list.innerHTML = '';

    examples.forEach(ex => {
      const div = document.createElement('div');
      div.className = 'example-item';
      div.innerHTML = `
        <div class="example-cn" lang="zh">${ex.cn}</div>
        <div class="example-en">${ex.en}</div>
        <div class="example-vi">${ex.vi}</div>
      `;
      list.appendChild(div);
    });
  }

  // ── Init + listen for lang changes ────────────────────────────────────────
  applyLang(getLang());

  window.addEventListener('wz:langchange', (e: Event) => {
    applyLang((e as CustomEvent).detail.lang as Lang);
  });

  // ── Favorites ─────────────────────────────────────────────────────────────
  const favBtn   = document.getElementById('fav-btn')!;
  const favIcon  = document.getElementById('fav-icon')!;

  function updateFavUI(active: boolean) {
    favBtn.classList.toggle('active', active);
    const lang = getLang();
    const favLabel = document.getElementById('fav-label')!;
    favLabel.textContent = active ? UI[lang].favorited : UI[lang].favorite;
    favIcon.setAttribute('fill', active ? 'currentColor' : 'none');
  }
  updateFavUI(isFavorite(entry.id));
  favBtn.addEventListener('click', () => {
    updateFavUI(toggleFavorite(entry));
  });

  // ── Speech ────────────────────────────────────────────────────────────────
  const speakBtn   = document.getElementById('speak-btn')!;
  const speakLabel = document.getElementById('speak-label')!;

  function speak(text: string) {
    if (!('speechSynthesis' in window)) { alert('Trình duyệt không hỗ trợ phát âm.'); return; }
    window.speechSynthesis.cancel();
    const utt = new SpeechSynthesisUtterance(text);
    utt.lang = 'zh-CN'; utt.rate = 0.85; utt.pitch = 1;
    const lang = getLang();
    speakBtn.classList.add('speaking');
    speakLabel.textContent = UI[lang].pronouncing;
    utt.onend = utt.onerror = () => {
      speakBtn.classList.remove('speaking');
      speakLabel.textContent = UI[getLang()].pronounce;
    };
    window.speechSynthesis.speak(utt);
  }
  speakBtn.addEventListener('click', () => speak(entry.simplified));
</script>
