---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import { Book, Notebook, Pen, Search, Plus, Trash } from 'lucide-astro';

const TABS = [
  { id: 'notebook', label: 'Sổ tay từ vựng', icon: 'Book' },
  { id: 'notes', label: 'Ghi chú cá nhân', icon: 'Notebook' },
  { id: 'writing', label: 'Luyện viết', icon: 'Pen' },
];

const VOCAB_LIST = [
  {
    word: '发展',
    pinyin: 'fāzhǎn',
    meaning: 'phát triển',
    added: '2023-10-26',
    due: '2023-11-02',
  },
  {
    word: '经济',
    pinyin: 'jīngjì',
    meaning: 'kinh tế',
    added: '2023-10-25',
    due: '2023-11-01',
  },
  {
    word: '重要',
    pinyin: 'zhòngyào',
    meaning: 'quan trọng',
    added: '2023-10-24',
    due: '2023-10-31',
  },
  {
    word: '环境',
    pinyin: 'huánjìng',
    meaning: 'môi trường',
    added: '2023-10-23',
    due: '2023-10-30',
  },
  {
    word: '政府',
    pinyin: 'zhèngfǔ',
    meaning: 'chính phủ',
    added: '2023-10-22',
    due: '2023-10-29',
  },
];

const ICONS = { Book, Notebook, Pen };
---

<BaseLayout title="Sổ tay — WenZi">
  <div class="min-h-screen bg-slate-50 text-slate-950">
    <Header activePage="notebook" />

    <main class="px-4 py-6 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-slate-900">Sổ tay của bạn</h1>
            <p class="mt-1 text-sm text-slate-500">Quản lý từ vựng, ghi chú và bài viết của bạn ở đây.</p>
          </div>
          <button class="inline-flex items-center gap-2 rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800">
            <Plus class="h-4 w-4" />
            <span>Thêm mục mới</span>
          </button>
        </div>

        <div class="mb-6 flex flex-wrap items-center border-b border-slate-200">
          {TABS.map((tab, index) => {
            const Icon = ICONS[tab.icon];
            return (
              <button class="notebook-tab flex items-center gap-2 border-b-2 px-4 py-3 text-sm font-semibold transition ${index === 0 ? 'border-slate-900 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}" data-tab={tab.id}>
                <Icon class="h-4 w-4" />
                <span>{tab.label}</span>
              </button>
            );
          })}
        </div>

        <div id="notebook-content">
          <div class="space-y-4">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <label class="relative flex-1 min-w-[280px] text-slate-900">
                <span class="sr-only">Tìm kiếm từ vựng...</span>
                <Search class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
                <input type="search" placeholder="Tìm kiếm từ vựng..." class="w-full rounded-xl border border-slate-200/80 bg-white py-2.5 pl-10 pr-4 text-sm text-slate-700 outline-none transition focus:border-slate-400 focus:ring-1 focus:ring-slate-100" />
              </label>
              <div class="flex items-center gap-2">
                <select class="rounded-xl border border-slate-200/80 bg-white px-3 py-2.5 text-sm text-slate-600 outline-none focus:border-slate-400 focus:ring-1 focus:ring-slate-100">
                  <option value="all">Tất cả</option>
                  <option value="due">Sắp đến hạn</option>
                  <option value="new">Mới thêm</option>
                  <option value="learned">Đã học</option>
                </select>
                <button class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200/80 bg-white text-slate-600 transition hover:bg-slate-100">
                  <Trash class="h-4 w-4" />
                </button>
              </div>
            </div>

            <div class="overflow-x-auto rounded-xl border border-slate-200/80 bg-white">
              <table class="min-w-full divide-y divide-slate-200/80 text-sm">
                <thead class="bg-slate-50/70">
                  <tr>
                    <th class="w-12 px-4 py-3 text-left"><input type="checkbox" class="rounded border-slate-300" /></th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Từ vựng</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Pinyin</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Nghĩa</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Ngày thêm</th>
                    <th class="px-4 py-3 text-left font-semibold text-slate-700">Ngày ôn tập</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200/80">
                  {VOCAB_LIST.map((item) => (
                    <tr>
                      <td class="w-12 px-4 py-3"><input type="checkbox" class="rounded border-slate-300" /></td>
                      <td class="px-4 py-3 font-semibold text-slate-900">{item.word}</td>
                      <td class="px-4 py-3 text-slate-600">{item.pinyin}</td>
                      <td class="px-4 py-3 text-slate-600">{item.meaning}</td>
                      <td class="px-4 py-3 text-slate-600">{item.added}</td>
                      <td class="px-4 py-3 text-slate-600">{item.due}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
<script is:inline>
    function updateActiveTab(tabId) {
        const tabs = document.querySelectorAll('.notebook-tab');
        tabs.forEach(tab => {
            const isSelected = tab.dataset.tab === tabId;
            tab.classList.toggle('border-slate-900', isSelected);
            tab.classList.toggle('text-slate-900', isSelected);
            tab.classList.toggle('border-transparent', !isSelected);
            tab.classList.toggle('text-slate-500', !isSelected);
        });
    }

    const tabs = document.querySelectorAll('.notebook-tab');
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            updateActiveTab(tab.dataset.tab);
        });
    });
</script>