---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
export const prerender = true;

const HSK_BOOKS = [
  { id: 'hsk1', label: 'HSK 1', count: 150, color: '#22c55e' },
  { id: 'hsk2', label: 'HSK 2', count: 150, color: '#84cc16' },
  { id: 'hsk3', label: 'HSK 3', count: 300, color: '#eab308' },
  { id: 'hsk4', label: 'HSK 4', count: 600, color: '#f97316' },
  { id: 'hsk5', label: 'HSK 5', count: 1300, color: '#ef4444' },
  { id: 'hsk6', label: 'HSK 6', count: 2500, color: '#dc2626' },
  { id: 'hsk79', label: 'HSK 7–9', count: 5000, color: '#9333ea' },
];
const TOCFL_BOOKS = [
  { id: 'tocfl1', label: 'TOCFL 1', count: 500, color: '#0ea5e9' },
  { id: 'tocfl2', label: 'TOCFL 2', count: 1000, color: '#2563eb' },
  { id: 'tocfl3', label: 'TOCFL 3', count: 2000, color: '#4f46e5' },
  { id: 'tocfl4', label: 'TOCFL 4', count: 3000, color: '#7c3aed' },
];
---

<BaseLayout title="Sổ tay — WenZi">
<div class="page">
  <Header activePage="notebook" />

  <main class="nb-main">
    <div class="nb-container">

      <!-- ── Tab Switcher ─────────────────────────────────────────────── -->
      <div class="tab-bar" role="tablist">
        <button class="tab tab--active" id="tab-notebooks" role="tab"
          aria-selected="true" aria-controls="view-notebooks" type="button">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          Sổ tay
        </button>
        <button class="tab" id="tab-ai" role="tab"
          aria-selected="false" aria-controls="view-ai" type="button">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/>
          </svg>
          Bài học AI
        </button>
      </div>

      <!-- ══ VIEW: SỔ TAY ══════════════════════════════════════════════ -->
      <div id="view-notebooks" class="nb-layout" role="tabpanel">

        <!-- Sidebar -->
        <aside class="nb-sidebar">
          <div class="srs-card">
            <div class="srs-header">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/>
                <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/>
                <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/>
                <path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/>
                <path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/>
                <path d="M3.477 10.896a4 4 0 0 1 .585-.396"/>
                <path d="M19.938 10.5a4 4 0 0 1 .585.396"/>
                <path d="M6 18a4 4 0 0 1-1.967-.516"/>
                <path d="M19.967 17.484A4 4 0 0 1 18 18"/>
              </svg>
              <span class="srs-title">Lặp lại ngắt quãng</span>
            </div>

            <div class="srs-levels" id="srs-levels">
              <!-- Rendered by JS -->
            </div>

            <button class="srs-review-btn" id="srs-review-btn" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                <path d="M3 3v5h5"/>
                <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
                <path d="M16 16h5v5"/>
              </svg>
              Ôn tập ngay — <span id="srs-due-count">0</span> từ
            </button>

            <div class="srs-tip">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 16v-4M12 8h.01"/>
              </svg>
              Ôn luyện đều đặn mỗi ngày để ghi nhớ lâu hơn.
            </div>
          </div>

          <!-- Quick stats -->
          <div class="sidebar-stats" id="sidebar-stats">
            <div class="stat-item">
              <span class="stat-num" id="stat-total">0</span>
              <span class="stat-label">Tổng từ</span>
            </div>
            <div class="stat-item">
              <span class="stat-num" id="stat-notebooks">0</span>
              <span class="stat-label">Sổ tay</span>
            </div>
            <div class="stat-item">
              <span class="stat-num" id="stat-streak">0</span>
              <span class="stat-label">Ngày liên tiếp</span>
            </div>
          </div>
        </aside>

        <!-- Main content -->
        <div class="nb-content">

          <!-- Section: Cá nhân -->
          <section class="nb-section">
            <div class="section-hdr">
              <div class="section-hdr-left">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
                </svg>
                <h2 class="section-title">Cá nhân</h2>
              </div>
              <button class="btn-create" id="btn-create-nb" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
                Tạo sổ tay
              </button>
            </div>

            <div class="personal-grid" id="personal-grid">
              <!-- Rendered by JS -->
            </div>
            <div class="empty-personal hidden" id="empty-personal">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/>
                <path d="M12 10v6M9 13h6"/>
              </svg>
              <p>Bạn chưa có sổ tay nào.</p>
              <p class="empty-sub">Nhấn "Tạo sổ tay" để bắt đầu!</p>
            </div>
          </section>

          <!-- Section: Miễn phí -->
          <section class="nb-section">
            <div class="section-hdr">
              <div class="section-hdr-left">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <h2 class="section-title">Miễn phí</h2>
              </div>
            </div>

            <p class="subsection-label">HSK (Hán ngữ tiêu chuẩn)</p>
            <div class="books-grid">
              {HSK_BOOKS.map(b => (
                <button class="book-card" type="button"
                  data-book-id={b.id} data-book-label={b.label} data-book-count={b.count}
                  style={`--book-color: ${b.color}`}>
                  <div class="book-icon-wrap" style={`background: color-mix(in srgb, ${b.color} 12%, transparent)`}>
                    <span class="book-hz" lang="zh" style={`color: ${b.color}`}>字</span>
                  </div>
                  <span class="book-name">{b.label}</span>
                  <span class="book-count">{b.count.toLocaleString()} từ</span>
                </button>
              ))}
            </div>

            <p class="subsection-label" style="margin-top:1.25rem">TOCFL (Tiêu chuẩn Đài Loan)</p>
            <div class="books-grid">
              {TOCFL_BOOKS.map(b => (
                <button class="book-card" type="button"
                  data-book-id={b.id} data-book-label={b.label} data-book-count={b.count}
                  style={`--book-color: ${b.color}`}>
                  <div class="book-icon-wrap" style={`background: color-mix(in srgb, ${b.color} 12%, transparent)`}>
                    <span class="book-hz" lang="zh" style={`color: ${b.color}`}>字</span>
                  </div>
                  <span class="book-name">{b.label}</span>
                  <span class="book-count">{b.count.toLocaleString()} từ</span>
                </button>
              ))}
            </div>
          </section>

          <!-- Section: Cao cấp -->
          <section class="nb-section">
            <div class="section-hdr">
              <div class="section-hdr-left">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                  stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.892 9.007a1 1 0 0 1-.947.685H5.857a1 1 0 0 1-.946-.685L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"/>
                  <path d="M5 21h14"/>
                </svg>
                <h2 class="section-title">Cao cấp <span class="crown-badge">👑</span></h2>
              </div>
              <span class="premium-tag">Sắp ra mắt</span>
            </div>
            <div class="premium-empty">
              <div class="premium-empty-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <p class="premium-empty-title">Nội dung cao cấp</p>
              <p class="premium-empty-sub">Bộ từ vựng theo ngành nghề, HSK chuyên sâu và nhiều tính năng học tập nâng cao sẽ sớm được mở khóa.</p>
            </div>
          </section>

        </div>
      </div>

      <!-- ══ VIEW: CHI TIẾT SỔ TAY ════════════════════════════════════ -->
      <div id="view-detail" class="nb-layout hidden" role="tabpanel">
        <aside class="nb-sidebar">
          <!-- Study tools -->
          <div class="study-card">
            <h3 class="study-title">Ôn tập</h3>

            <div class="tool-search-wrap">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
              </svg>
              <input type="search" id="word-search" class="tool-search"
                placeholder="Tìm trong sổ tay..." autocomplete="off"/>
            </div>

            <button class="tool-btn" id="btn-flashcard" type="button">
              <span class="tool-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="M12 9v6M9 12h6"/>
                </svg>
              </span>
              <div class="tool-text">
                <span class="tool-name">Flashcard</span>
                <span class="tool-desc">Lật thẻ ôn từ</span>
              </div>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>

            <button class="tool-btn" id="btn-write" type="button">
              <span class="tool-icon tool-icon--write">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 20h9"/>
                  <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
              </span>
              <div class="tool-text">
                <span class="tool-name">Luyện viết</span>
                <span class="tool-desc">Thứ tự nét bút</span>
              </div>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>

            <div class="tool-progress">
              <div class="progress-row">
                <span>Đã học</span>
                <span id="detail-learned">0 / 0 từ</span>
              </div>
              <div class="progress-bar-wrap">
                <div class="progress-bar-fill" id="detail-progress-bar" style="width:0%"></div>
              </div>
            </div>
          </div>
        </aside>

        <div class="nb-content">
          <!-- Detail header -->
          <div class="detail-header">
            <button class="btn-back" id="btn-back-detail" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 5l-7 7 7 7"/>
              </svg>
              Quay lại
            </button>
            <div class="detail-title-row">
              <h1 class="detail-title" id="detail-title">Sổ tay</h1>
              <button class="btn-icon-sm" id="btn-edit-name" type="button" title="Đổi tên">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
                </svg>
              </button>
            </div>
            <div class="detail-meta" id="detail-meta">
              <span id="detail-count-badge">0 từ</span>
              <span class="dot">·</span>
              <span id="detail-date">—</span>
            </div>
          </div>

          <!-- Word grid -->
          <div class="word-grid" id="word-grid"></div>
          <div class="empty-words hidden" id="empty-words">
            <p>Sổ tay trống. Thêm từ từ trang chi tiết từ điển.</p>
          </div>
        </div>
      </div>

      <!-- ══ VIEW: BÀI HỌC AI ══════════════════════════════════════════ -->
      <div id="view-ai" class="nb-layout hidden" role="tabpanel">

        <aside class="nb-sidebar">
          <div class="ai-form-card">
            <div class="ai-form-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/>
              </svg>
              Tạo bài học thông minh
            </div>

            <label class="ai-label">Cấp độ của bạn</label>
            <select class="ai-select" id="ai-level">
              <option value="beginner">Sơ cấp (HSK 1–2)</option>
              <option value="elementary">Cơ bản (HSK 3–4)</option>
              <option value="intermediate" selected>Trung cấp (HSK 4–5)</option>
              <option value="advanced">Cao cấp (HSK 6+)</option>
            </select>

            <label class="ai-label">Chủ đề muốn học</label>
            <input type="text" id="ai-topic" class="ai-input"
              placeholder="Ví dụ: Ăn uống, Du lịch, Công nghệ..."
              maxlength="60"/>

            <button class="ai-generate-btn" id="ai-generate-btn" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/>
              </svg>
              Tạo bài học
            </button>

            <div class="ai-suggestions">
              <p class="ai-suggestions-title">Gợi ý cho bạn</p>
              <div class="ai-suggest-tags">
                {['Du lịch', 'Ẩm thực', 'Công nghệ', 'Gia đình', 'Kinh doanh', 'Sức khỏe'].map(s => (
                  <button class="ai-suggest-tag" data-topic={s} type="button">{s}</button>
                ))}
              </div>
            </div>

            <div class="ai-history-section">
              <p class="ai-suggestions-title">Lịch sử</p>
              <div id="ai-lesson-history" class="ai-hist-list">
                <p class="ai-hist-empty">Chưa có bài học nào.</p>
              </div>
            </div>
          </div>
        </aside>

        <div class="nb-content">
          <div class="roadmap-header">
            <h2 class="roadmap-title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
              </svg>
              Học theo lộ trình 🎯
            </h2>
            <p class="roadmap-sub">Lộ trình học tiếng Trung từ cơ bản đến nâng cao, được cá nhân hóa theo mục tiêu của bạn.</p>
          </div>

          <div class="roadmap-grid" id="roadmap-grid">
            <!-- Rendered by JS -->
          </div>

          <div class="ai-lesson-result hidden" id="ai-lesson-result">
            <div class="lesson-result-header">
              <h3 class="lesson-result-title" id="lesson-result-title">Bài học mới</h3>
              <button class="btn-icon-sm" id="btn-close-lesson" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
              </button>
            </div>
            <div class="lesson-words" id="lesson-words"></div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- ── Create Notebook Modal ────────────────────────────────────────── -->
  <div class="modal-overlay hidden" id="modal-create">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <h2 class="modal-title" id="modal-title">Tạo sổ tay mới</h2>
      <input type="text" id="modal-name" class="modal-input"
        placeholder="Tên sổ tay (ví dụ: Du lịch Trung Quốc)" maxlength="40"/>
      <div class="modal-footer">
        <button class="modal-btn modal-btn--cancel" id="modal-cancel" type="button">Hủy</button>
        <button class="modal-btn modal-btn--confirm" id="modal-confirm" type="button">Tạo</button>
      </div>
    </div>
  </div>

  <!-- ── Flashcard Modal ───────────────────────────────────────────────── -->
  <div class="modal-overlay hidden" id="modal-fc">
    <div class="modal modal--wide" role="dialog" aria-modal="true">
      <div class="fc-card" id="fc-card">
        <div class="fc-front" id="fc-front">
          <span class="fc-hanzi" id="fc-hanzi" lang="zh">—</span>
        </div>
        <div class="fc-back hidden" id="fc-back">
          <span class="fc-pinyin" id="fc-pinyin">—</span>
          <span class="fc-meaning" id="fc-meaning">—</span>
        </div>
      </div>
      <div class="fc-controls">
        <button class="fc-btn" id="fc-flip" type="button">Lật thẻ</button>
        <button class="fc-btn fc-btn--prev" id="fc-prev" type="button">◀</button>
        <span class="fc-counter" id="fc-counter">1 / 1</span>
        <button class="fc-btn fc-btn--next" id="fc-next" type="button">▶</button>
        <button class="fc-btn fc-btn--close" id="fc-close" type="button">✕ Đóng</button>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>WenZi © 2026 — MIT License</p>
  </footer>
</div>
</BaseLayout>

<style>
  .page { display: flex; flex-direction: column; min-height: 100dvh; }

  /* Main */
  .nb-main { flex: 1; padding: 1.5rem; background: var(--color-bg); }
  .nb-container { max-width: 1120px; margin: 0 auto; }

  /* Tabs */
  .tab-bar {
    display: flex; gap: .4rem;
    margin-bottom: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: .3rem;
    width: fit-content;
    box-shadow: var(--shadow-sm);
  }
  .tab {
    display: flex; align-items: center; gap: .45rem;
    padding: .5rem 1.1rem;
    border-radius: 9px;
    border: none; background: transparent;
    font-size: .875rem; font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all .18s;
  }
  .tab:hover { background: var(--color-bg); color: var(--color-text); }
  .tab--active {
    background: var(--color-primary);
    color: #fff;
    box-shadow: 0 2px 8px rgba(43,76,126,.25);
  }

  /* 2-column layout */
  .nb-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.25rem;
    align-items: start;
  }
