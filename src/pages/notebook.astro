<script>
  // ── Constants ────────────────────────────────────────────────────────────
  const NB_KEY  = 'wz-notebooks';
  const SRS_KEY = 'wz-srs';

  // ── Types ────────────────────────────────────────────────────────────────
  interface NbWord { simplified: string; traditional: string; pinyin: string; meaning: string; color: string; }
  interface Notebook { id: string; name: string; words: NbWord[]; createdAt: string; srs: Record<string, number>; }

  // ── Storage ───────────────────────────────────────────────────────────────
  function loadNotebooks(): Notebook[] {
    try { return JSON.parse(localStorage.getItem(NB_KEY) ?? '[]'); }
    catch { return []; }
  }
  function saveNotebooks(arr: Notebook[]): void {
    try { localStorage.setItem(NB_KEY, JSON.stringify(arr)); }
    catch {}
  }

  // ── Demo data ────────────────────────────────────────────────────────────
  const DEMO_WORDS: NbWord[] = [
    { simplified:'战争', traditional:'戰爭', pinyin:'zhànzhēng', meaning:'Chiến tranh', color:'#dc2626' },
    { simplified:'士兵', traditional:'士兵', pinyin:'shìbīng', meaning:'Binh lính', color:'#b45309' },
    { simplified:'武器', traditional:'武器', pinyin:'wǔqì', meaning:'Vũ khí', color:'#4f46e5' },
    { simplified:'胜利', traditional:'勝利', pinyin:'shènglì', meaning:'Chiến thắng', color:'#16a34a' },
    { simplified:'失败', traditional:'失敗', pinyin:'shībài', meaning:'Thất bại', color:'#ef4444' },
    { simplified:'军队', traditional:'軍隊', pinyin:'jūnduì', meaning:'Quân đội', color:'#7c3aed' },
    { simplified:'炸弹', traditional:'炸彈', pinyin:'zhàdàn', meaning:'Bom đạn', color:'#dc2626' },
    { simplified:'和平', traditional:'和平', pinyin:'hépíng', meaning:'Hòa bình', color:'#0ea5e9' },
    { simplified:'战场', traditional:'戰場', pinyin:'zhànchǎng', meaning:'Chiến trường', color:'#b45309' },
    { simplified:'英雄', traditional:'英雄', pinyin:'yīngxióng', meaning:'Anh hùng', color:'#f59e0b' },
  ];

  function ensureDemo(): void {
    let nbs = loadNotebooks();
    if (!nbs.find(n => n.id === 'demo-war')) {
      nbs.unshift({ id: 'demo-war', name: 'Chủ đề Chiến tranh', words: DEMO_WORDS, createdAt: '2026-06-10', srs: {} });
      saveNotebooks(nbs);
    }
  }
  ensureDemo();

  // ── SRS ──────────────────────────────────────────────────────────────────
  const SRS_COLORS = ['#ef4444','#f97316','#eab308','#22c55e','#3b82f6'];
  const SRS_LABELS = ['Cấp 1','Cấp 2','Cấp 3','Cấp 4','Cấp 5'];

  function getSRSData(): number[] {
    try {
      const d = JSON.parse(localStorage.getItem(SRS_KEY) ?? 'null');
      if (Array.isArray(d) && d.length === 5) return d;
    } catch {}
    return [8, 5, 12, 7, 3];
  }

  function renderSRS(): void {
    const levels = getSRSData();
    const total  = levels.reduce((a, b) => a + b, 0);
    const el     = document.getElementById('srs-levels')!;
    el.innerHTML = levels.map((n, i) => `
      <div class="srs-level-row">
        <span class="srs-level-label">${SRS_LABELS[i]}</span>
        <div class="srs-level-bar-wrap">
          <div class="srs-level-bar-fill" style="width:${total ? (n/total*100).toFixed(1) : 0}%;background:${SRS_COLORS[i]}"></div>
        </div>
        <span class="srs-level-count">${n}</span>
      </div>`).join('');

    const due = levels[0] + Math.floor(levels[1] * .4);
    document.getElementById('srs-due-count')!.textContent = String(due);
    (document.getElementById('srs-review-btn') as HTMLButtonElement).disabled = due === 0;
  }

  // ── Personal notebooks ───────────────────────────────────────────────────
  function renderPersonal(): void {
    const nbs    = loadNotebooks();
    const grid   = document.getElementById('personal-grid')!;
    const empty  = document.getElementById('empty-personal')!;

    grid.innerHTML = '';
    if (nbs.length === 0) {
      empty.classList.remove('hidden');
      return;
    }
    empty.classList.add('hidden');

    nbs.forEach(nb => {
      const btn = document.createElement('button');
      btn.type  = 'button';
      btn.className = 'personal-nb-card';
      btn.dataset.nbId = nb.id;
      btn.innerHTML = `
        <div class="nb-card-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <span class="nb-card-name">${nb.name}</span>
        <span class="nb-card-count">${nb.words.length} từ · ${nb.createdAt}</span>
      `;
      btn.addEventListener('click', () => openDetail(nb.id));
      grid.appendChild(btn);
    });

    const totalWords = nbs.reduce((a, n) => a + n.words.length, 0);
    document.getElementById('stat-total')!.textContent    = String(totalWords);
    document.getElementById('stat-notebooks')!.textContent = String(nbs.length);
  }

  // ── Detail view ───────────────────────────────────────────────────────────
  let currentNbId = '';
  let allWords: NbWord[] = [];

  function openDetail(id: string): void {
    const nbs = loadNotebooks();
    const nb  = nbs.find(n => n.id === id);
    if (!nb) return;
    currentNbId = id;
    allWords    = nb.words;

    document.getElementById('view-notebooks')!.classList.add('hidden');
    document.getElementById('view-detail')!.classList.remove('hidden');

    document.getElementById('detail-title')!.textContent       = nb.name;
    document.getElementById('detail-date')!.textContent        = 'Tạo: ' + nb.createdAt;
    document.getElementById('detail-count-badge')!.textContent = `${nb.words.length} từ`;

    const learned = Math.floor(nb.words.length * 0.6);
    document.getElementById('detail-learned')!.textContent = `${learned} / ${nb.words.length} từ`;
    (document.getElementById('detail-progress-bar') as HTMLElement).style.width =
      nb.words.length ? `${(learned/nb.words.length*100).toFixed(0)}%` : '0%';

    renderWordGrid(nb.words);
  }

  function renderWordGrid(words: NbWord[]): void {
    const grid  = document.getElementById('word-grid')!;
    const empty = document.getElementById('empty-words')!;
    grid.innerHTML = '';
    if (words.length === 0) { empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');

    words.forEach(w => {
      const card = document.createElement('div');
      card.className = 'word-card';
      card.innerHTML = `
        <div class="word-card-img" style="background:${w.color}">
          <span lang="zh">${w.simplified[0]}</span>
        </div>
        <div class="word-card-body">
          <span class="wc-hanzi" lang="zh">${w.simplified}</span>
          ${w.traditional !== w.simplified ? `<span class="wc-trad" lang="zh">${w.traditional}</span>` : ''}
          <span class="wc-pinyin">${w.pinyin}</span>
          <span class="wc-meaning">${w.meaning}</span>
          <div class="wc-actions">
            <button class="wc-btn" type="button">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
              Ghi chú
            </button>
            <button class="wc-btn" type="button" onclick="speakWord('${w.simplified}')">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
              </svg>
              Nghe
            </button>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  (window as any).speakWord = (text: string) => {
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'zh-CN'; u.rate = 0.9;
    speechSynthesis.speak(u);
  };

  // ── Word search filter ────────────────────────────────────────────────────
  document.getElementById('word-search')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.trim().toLowerCase();
    const filtered = q ? allWords.filter(w =>
      w.simplified.includes(q) || w.pinyin.toLowerCase().includes(q) || w.meaning.toLowerCase().includes(q)
    ) : allWords;
    renderWordGrid(filtered);
  });

  // ── Back button ───────────────────────────────────────────────────────────
  document.getElementById('btn-back-detail')?.addEventListener('click', () => {
    document.getElementById('view-detail')!.classList.add('hidden');
    document.getElementById('view-notebooks')!.classList.remove('hidden');
    (document.getElementById('word-search') as HTMLInputElement).value = '';
  });

  // ── Create notebook modal ─────────────────────────────────────────────────
  document.getElementById('btn-create-nb')?.addEventListener('click', () => {
    document.getElementById('modal-create')!.classList.remove('hidden');
    (document.getElementById('modal-name') as HTMLInputElement).value = '';
    setTimeout(() => (document.getElementById('modal-name') as HTMLInputElement).focus(), 100);
  });
  document.getElementById('modal-cancel')?.addEventListener('click', () => {
    document.getElementById('modal-create')!.classList.add('hidden');
  });
  document.getElementById('modal-confirm')?.addEventListener('click', () => {
    const name = (document.getElementById('modal-name') as HTMLInputElement).value.trim();
    if (!name) return;
    const nb: Notebook = { id: `nb-${Date.now()}`, name, words: [], createdAt: new Date().toISOString().slice(0,10), srs: {} };
    const nbs = loadNotebooks();
    nbs.unshift(nb);
    saveNotebooks(nbs);
    document.getElementById('modal-create')!.classList.add('hidden');
    renderPersonal();
    openDetail(nb.id);
  });

  // ── Edit name ─────────────────────────────────────────────────────────────
  document.getElementById('btn-edit-name')?.addEventListener('click', () => {
    const nbs  = loadNotebooks();
    const nb   = nbs.find(n => n.id === currentNbId);
    if (!nb) return;
    const newName = prompt('Đổi tên sổ tay:', nb.name);
    if (newName?.trim()) {
      nb.name = newName.trim();
      saveNotebooks(nbs);
      document.getElementById('detail-title')!.textContent = nb.name;
      renderPersonal();
    }
  });

  // ── HSK/TOCFL book cards ──────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.book-card').forEach(btn => {
    btn.addEventListener('click', () => {
      const label = btn.dataset.bookLabel ?? '';
      const count = btn.dataset.bookCount ?? '0';
      alert(`📚 ${label} — ${parseInt(count).toLocaleString()} từ\n\nTính năng tải dữ liệu ${label} đang được phát triển. Vui lòng quay lại sau!`);
    });
  });

  // ── Flashcard ─────────────────────────────────────────────────────────────
  let fcWords: NbWord[] = [];
  let fcIdx   = 0;
  let fcFlipped = false;

  function openFlashcard(): void {
    const nbs = loadNotebooks();
    const nb  = nbs.find(n => n.id === currentNbId);
    if (!nb || nb.words.length === 0) { alert('Sổ tay chưa có từ nào.'); return; }
    fcWords   = [...nb.words].sort(() => Math.random() - .5);
    fcIdx     = 0; fcFlipped = false;
    renderFCCard();
    document.getElementById('modal-fc')!.classList.remove('hidden');
  }

  function renderFCCard(): void {
    const w = fcWords[fcIdx];
    document.getElementById('fc-hanzi')!.textContent   = w.simplified;
    document.getElementById('fc-pinyin')!.textContent  = w.pinyin;
    document.getElementById('fc-meaning')!.textContent = w.meaning;
    document.getElementById('fc-front')!.classList.remove('hidden');
    document.getElementById('fc-back')!.classList.add('hidden');
    document.getElementById('fc-counter')!.textContent = `${fcIdx+1} / ${fcWords.length}`;
    fcFlipped = false;
  }

  document.getElementById('btn-flashcard')?.addEventListener('click', openFlashcard);
  document.getElementById('fc-flip')?.addEventListener('click', () => {
    fcFlipped = !fcFlipped;
    document.getElementById('fc-front')!.classList.toggle('hidden', fcFlipped);
    document.getElementById('fc-back')!.classList.toggle('hidden', !fcFlipped);
  });
  document.getElementById('fc-card')?.addEventListener('click', () => {
    document.getElementById('fc-flip')!.click();
  });
  document.getElementById('fc-prev')?.addEventListener('click', () => {
    if (fcIdx > 0) { fcIdx--; renderFCCard(); }
  });
  document.getElementById('fc-next')?.addEventListener('click', () => {
    if (fcIdx < fcWords.length - 1) { fcIdx++; renderFCCard(); }
  });
  document.getElementById('fc-close')?.addEventListener('click', () => {
    document.getElementById('modal-fc')!.classList.add('hidden');
  });

  document.getElementById('btn-write')?.addEventListener('click', () => {
    window.location.href = `/word/${0}`;
  });

  // ── Tab switcher ──────────────────────────────────────────────────────────
  const TABS: [string, string][] = [
    ['tab-notebooks', 'view-notebooks'],
    ['tab-ai',        'view-ai'],
  ];
  document.querySelectorAll<HTMLButtonElement>('.tab').forEach((btn, i) => {
    btn.addEventListener('click', () => {
      TABS.forEach(([tabId, viewId], j) => {
        const t = document.getElementById(tabId)!;
        const v = document.getElementById(viewId)!;
        const active = j === i;
        t.classList.toggle('tab--active', active);
        t.setAttribute('aria-selected', String(active));
        if (i === 1 && active && document.getElementById('view-detail')!.classList.contains('hidden') === false) {
          document.getElementById('view-detail')!.classList.add('hidden');
        }
        v.classList.toggle('hidden', !active);
      });
    });
  });

  // ── Roadmap data ──────────────────────────────────────────────────────────
  const ROADMAP = [
    { emoji:'🌱', title:'Những bước chân đầu tiên', desc:'Chào hỏi, số đếm, màu sắc. HSK 1–2.', level:'HSK 1', color:'#22c55e', rc:'#dcfce7' },
    { emoji:'🏡', title:'Gia đình & Cuộc sống', desc:'Thành viên gia đình, nhà cửa, sinh hoạt hàng ngày.', level:'HSK 2', color:'#3b82f6', rc:'#dbeafe' },
    { emoji:'🍜', title:'Ẩm thực & Thực phẩm', desc:'Gọi món, nấu ăn, các món đặc trưng Trung Hoa.', level:'HSK 2–3', color:'#f97316', rc:'#ffedd5' },
    { emoji:'🚇', title:'Hòa nhập & Khám phá', desc:'Đi lại, hỏi đường, giao thông công cộng.', level:'HSK 3', color:'#8b5cf6', rc:'#ede9fe' },
    { emoji:'💼', title:'Kinh doanh & Nghề nghiệp', desc:'Phỏng vấn, làm việc văn phòng, thương mại.', level:'HSK 4', color:'#0ea5e9', rc:'#e0f2fe' },
    { emoji:'📰', title:'Tin tức & Thời sự', desc:'Đọc hiểu báo chí, bình luận, phân tích sự kiện.', level:'HSK 5–6', color:'#dc2626', rc:'#fee2e2' },
  ];

  function renderRoadmap(): void {
    const grid = document.getElementById('roadmap-grid')!;
    grid.innerHTML = ROADMAP.map(r => `
      <button class="roadmap-card" type="button" style="--rc-color:${r.color}">
        <span class="rc-tag" style="background:${r.rc};color:${r.color}">${r.level}</span>
        <span class="rc-title">${r.emoji} ${r.title}</span>
        <span class="rc-desc">${r.desc}</span>
        <span class="rc-badge">Bắt đầu học →</span>
        <span class="rc-watermark" lang="zh">${r.emoji}</span>
      </button>`).join('');
  }

  // ── AI lesson generation (mock) ───────────────────────────────────────────
  const AI_LESSONS: Record<string, NbWord[]> = {
    'Du lịch': [
      { simplified:'机场', traditional:'機場', pinyin:'jīchǎng', meaning:'Sân bay', color:'#0ea5e9' },
      { simplified:'护照', traditional:'護照', pinyin:'hùzhào', meaning:'Hộ chiếu', color:'#4f46e5' },
      { simplified:'酒店', traditional:'酒店', pinyin:'jiǔdiàn', meaning:'Khách sạn', color:'#f97316' },
      { simplified:'景点', traditional:'景點', pinyin:'jǐngdiǎn', meaning:'Điểm tham quan', color:'#16a34a' },
      { simplified:'导游', traditional:'導遊', pinyin:'dǎoyóu', meaning:'Hướng dẫn viên', color:'#7c3aed' },
      { simplified:'旅行', traditional:'旅行', pinyin:'lǚxíng', meaning:'Du lịch, đi chơi', color:'#0ea5e9' },
    ],
    'Ẩm thực': [
      { simplified:'饺子', traditional:'餃子', pinyin:'jiǎozi', meaning:'Sủi cảo', color:'#f97316' },
      { simplified:'火锅', traditional:'火鍋', pinyin:'huǒguō', meaning:'Lẩu', color:'#dc2626' },
      { simplified:'米饭', traditional:'米飯', pinyin:'mǐfàn', meaning:'Cơm', color:'#eab308' },
      { simplified:'面条', traditional:'麵條', pinyin:'miàntiáo', meaning:'Mì sợi', color:'#f97316' },
      { simplified:'饮料', traditional:'飲料', pinyin:'yǐnliào', meaning:'Đồ uống', color:'#0ea5e9' },
      { simplified:'甜点', traditional:'甜點', pinyin:'tiándiǎn', meaning:'Tráng miệng', color:'#ec4899' },
    ],
    'Công nghệ': [
      { simplified:'人工智能', traditional:'人工智能', pinyin:'réngōng zhìnéng', meaning:'Trí tuệ nhân tạo', color:'#4f46e5' },
      { simplified:'手机', traditional:'手機', pinyin:'shǒujī', meaning:'Điện thoại di động', color:'#0ea5e9' },
      { simplified:'网络', traditional:'網絡', pinyin:'wǎngluò', meaning:'Mạng lưới, internet', color:'#16a34a' },
      { simplified:'软件', traditional:'軟件', pinyin:'ruǎnjiàn', meaning:'Phần mềm', color:'#8b5cf6' },
      { simplified:'数据', traditional:'數據', pinyin:'shùjù', meaning:'Dữ liệu', color:'#3b82f6' },
      { simplified:'编程', traditional:'編程', pinyin:'biānchéng', meaning:'Lập trình', color:'#f97316' },
    ],
  };

  function generateLesson(topic: string): void {
    const btn = document.getElementById('ai-generate-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '⏳ Đang tạo...';
    setTimeout(() => {
      btn.disabled = false;
      btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/></svg> Tạo bài học`;
      const words = AI_LESSONS[topic] ?? AI_LESSONS['Ẩm thực'];
      showLessonResult(topic, words);
      addAIHistory(topic);
    }, 1400);
  }

  function showLessonResult(topic: string, words: NbWord[]): void {
    const result = document.getElementById('ai-lesson-result')!;
    const title  = document.getElementById('lesson-result-title')!;
    const grid   = document.getElementById('lesson-words')!;
    title.textContent = `✨ Bài học: ${topic}`;
    grid.innerHTML = words.map(w => `
      <div class="lw-card">
        <span class="lw-hanzi" lang="zh">${w.simplified}</span>
        <span class="lw-pinyin">${w.pinyin}</span>
        <span class="lw-meaning">${w.meaning}</span>
      </div>`).join('');
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function addAIHistory(topic: string): void {
    const el = document.getElementById('ai-lesson-history')!;
    const empty = el.querySelector('.ai-hist-empty');
    if (empty) empty.remove();
    const existing = el.querySelector(`[data-topic="${topic}"]`);
    if (existing) return;
    const item = document.createElement('button');
    item.type = 'button';
    item.className = 'ai-hist-item';
    item.dataset.topic = topic;
    item.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ${topic}`;
    item.addEventListener('click', () => generateLesson(topic));
    el.prepend(item);
  }

  document.getElementById('ai-generate-btn')?.addEventListener('click', () => {
    const topic = (document.getElementById('ai-topic') as HTMLInputElement).value.trim() || 'Ẩm thực';
    generateLesson(topic);
  });

  document.querySelectorAll<HTMLButtonElement>('.ai-suggest-tag').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('ai-topic') as HTMLInputElement).value = btn.dataset.topic ?? '';
      generateLesson(btn.dataset.topic ?? '');
    });
  });

  document.getElementById('btn-close-lesson')?.addEventListener('click', () => {
    document.getElementById('ai-lesson-result')!.classList.add('hidden');
  });

  // ── Init ─────────────────────────────────────────────────────────────────
  renderSRS();
  renderPersonal();
  renderRoadmap();
  document.getElementById('stat-streak')!.textContent = '3';
</script>
