---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import { Grid, Heart, MessageCircle, Eye, Pin, Search, Crown, MessageSquareText } from 'lucide-astro';
export const prerender = true;

const currentUser = { name: 'Anh Nguyen', avatar: 'AN' };

const HOT_QUESTIONS = [
  'Làm thế nào để phân biệt 的、地、得 trong tiếng Trung?',
  'HSK 4 có bao nhiêu từ vựng cần học? Tài liệu nào tốt nhất?',
  'Cách luyện phát âm thanh điệu tiếng Trung cho người Việt?',
  'Sự khác biệt giữa 看 và 看看 trong văn nói?',
  'Kinh nghiệm thi TOCFL tại Đài Loan — chia sẻ từ người đã qua!',
];

const CATEGORIES = [
  { name: 'Học tiếng Trung', icon: 'MessageSquareText' },
  { name: 'Văn hóa Trung Quốc', icon: 'Grid' },
  { name: 'Dịch thuật', icon: 'Grid' },
  { name: 'Du học Trung Quốc', icon: 'Grid' },
  { name: 'Du lịch', icon: 'Grid' },
  { name: 'Góc chia sẻ', icon: 'MessageSquareText' },
  { name: 'Tìm bạn học chung', icon: 'Grid' },
  { name: 'Công nghệ thông tin', icon: 'Grid' },
  { name: 'Việc làm', icon: 'Grid' },
  { name: 'Cơ khí', icon: 'Grid' },
];

const FILTERS = ['Tất cả', 'Yêu thích', 'Quan tâm', 'BTV lựa chọn'];

const POSTS = [
  {
    id: 1,
    pinned: true,
    avatar: 'AN',
    name: 'Anh Nguyen',
    role: 'Mod',
    time: '2 giờ trước',
    category: 'Học tiếng Trung',
    title: '📌 [THÔNG BÁO] Quy định cộng đồng WenZi — Đọc trước khi tham gia',
    content:
      'Chào mừng bạn đến với cộng đồng WenZi! Để duy trì môi trường học tập lành mạnh và tích cực, vui lòng đọc kỹ các quy định sau trước khi đăng bài. Tôn trọng lẫn nhau, không spam, không quảng cáo ngoài luồng. Mọi thảo luận cần đảm bảo văn phong lịch sự và đúng chủ đề.',
    likes: 142,
    comments: 28,
    views: 3540,
    color: '#2b4c7e',
    liked: false,
  },
  {
    id: 2,
    pinned: false,
    avatar: 'MT',
    name: 'Minh Tú',
    role: '',
    time: '45 phút trước',
    category: 'Học tiếng Trung',
    title: 'Mẹo nhớ thanh điệu tiếng Trung siêu hiệu quả cho người Việt',
    content:
      'Sau 2 năm học tiếng Trung, mình đã tổng hợp được một số mẹo để ghi nhớ 4 thanh điệu (+ thanh nhẹ) một cách tự nhiên nhất. Bí quyết là gắn mỗi thanh với một hành động cơ thể: thanh 1 → giọng phẳng cao như hát, thanh 2 → giọng lên như hỏi, thanh 3 → giọng rơi xuống rồi lên, thanh 4 → giọng gãy và mạnh.',
    likes: 87,
    comments: 34,
    views: 1820,
    color: '#7c3aed',
    liked: false,
  },
  {
    id: 3,
    pinned: false,
    avatar: 'HT',
    name: 'Hồng Thái',
    role: 'HSK 5',
    time: '3 giờ trước',
    category: 'Du học Trung Quốc',
    title: 'Kinh nghiệm xin visa du học Trung Quốc 2026 — Hồ sơ cần chuẩn bị gì?',
    content:
      'Mình vừa nhận được visa du học Trung Quốc tuần trước. Quá trình xin visa khá phức tạp nhưng nếu chuẩn bị kỹ thì không khó. Bài viết này mình sẽ liệt kê đầy đủ các giấy tờ cần thiết và những lưu ý quan trọng để bạn tự tin nộp hồ sơ.',
    likes: 203,
    comments: 67,
    views: 4210,
    color: '#0ea5e9',
    liked: false,
  },
  {
    id: 4,
    pinned: false,
    avatar: 'LP',
    name: 'Lan Phương',
    role: '',
    time: '5 giờ trước',
    category: 'Góc chia sẻ',
    title: '分享：学了3个月汉语后的感想 — Cảm nhận sau 3 tháng học tiếng Trung',
    content:
      '我学中文已经三个月了。开始的时候很难，特别是声调。但是现在我可以用中文打招呼，点菜，还有买东西！ | Mình học tiếng Trung được 3 tháng rồi. Lúc đầu rất khó, đặc biệt là thanh điệu. Nhưng giờ mình có thể dùng tiếng Trung để chào hỏi, gọi món và mua đồ!',
    likes: 156,
    comments: 43,
    views: 2890,
    color: '#16a34a',
    liked: false,
  },
  {
    id: 5,
    pinned: false,
    avatar: 'DK',
    name: 'Đức Khoa',
    role: 'BTV',
    time: '1 ngày trước',
    category: 'Dịch thuật',
    title: 'Giải thích chi tiết: Khi nào dùng 把 trong câu tiếng Trung?',
    content:
      'Cấu trúc 把 (bǎ) là một trong những điểm ngữ pháp khiến người học hay nhầm lẫn nhất. Hôm nay mình sẽ giải thích chi tiết với ví dụ cụ thể: 把 được dùng khi động từ tác động lên tân ngữ xác định, tạo ra sự thay đổi và nhấn mạnh kết quả.',
    likes: 312,
    comments: 89,
    views: 6750,
    color: '#f97316',
    liked: false,
  },
];

const LEADERBOARD = {
  tuần: [
    { rank: 1, name: 'Minh Tú', avatar: 'MT', score: 2840, color: '#f59e0b' },
    { rank: 2, name: 'Hồng Thái', avatar: 'HT', score: 2210, color: '#94a3b8' },
    { rank: 3, name: 'Đức Khoa', avatar: 'DK', score: 1980, color: '#b45309' },
    { rank: 4, name: 'Lan Phương', avatar: 'LP', score: 1540 },
    { rank: 5, name: 'Anh Nguyen', avatar: 'AN', score: 1320 },
    { rank: 6, name: 'Quốc Bảo', avatar: 'QB', score: 1180 },
    { rank: 7, name: 'Thu Hà', avatar: 'TH', score: 987 },
    { rank: 8, name: 'Văn Long', avatar: 'VL', score: 854 },
    { rank: 9, name: 'Bích Ngọc', avatar: 'BN', score: 720 },
    { rank: 10, name: 'Hoàng Nam', avatar: 'HN', score: 612 },
  ],
  tháng: [
    { rank: 1, name: 'Đức Khoa', avatar: 'DK', score: 12400, color: '#f59e0b' },
    { rank: 2, name: 'Minh Tú', avatar: 'MT', score: 9870, color: '#94a3b8' },
    { rank: 3, name: 'Thu Hà', avatar: 'TH', score: 8200, color: '#b45309' },
    { rank: 4, name: 'Hồng Thái', avatar: 'HT', score: 7540 },
    { rank: 5, name: 'Lan Phương', avatar: 'LP', score: 6890 },
    { rank: 6, name: 'Văn Long', avatar: 'VL', score: 5430 },
    { rank: 7, name: 'Anh Nguyen', avatar: 'AN', score: 4210 },
    { rank: 8, name: 'Bích Ngọc', avatar: 'BN', score: 3870 },
    { rank: 9, name: 'Quốc Bảo', avatar: 'QB', score: 3120 },
    { rank: 10, name: 'Hoàng Nam', avatar: 'HN', score: 2560 },
  ],
  năm: [
    { rank: 1, name: 'Anh Nguyen', avatar: 'AN', score: 145000, color: '#f59e0b' },
    { rank: 2, name: 'Đức Khoa', avatar: 'DK', score: 128000, color: '#94a3b8' },
    { rank: 3, name: 'Minh Tú', avatar: 'MT', score: 112000, color: '#b45309' },
    { rank: 4, name: 'Lan Phương', avatar: 'LP', score: 94000 },
    { rank: 5, name: 'Thu Hà', avatar: 'TH', score: 87000 },
    { rank: 6, name: 'Hồng Thái', avatar: 'HT', score: 76000 },
    { rank: 7, name: 'Quốc Bảo', avatar: 'QB', score: 65000 },
    { rank: 8, name: 'Bích Ngọc', avatar: 'BN', score: 54000 },
    { rank: 9, name: 'Văn Long', avatar: 'VL', score: 43000 },
    { rank: 10, name: 'Hoàng Nam', avatar: 'HN', score: 38000 },
  ],
};

const ICONS = { Grid, Heart, MessageCircle, Eye, Pin, Search, Crown, MessageSquareText };
---

<BaseLayout title="Cộng đồng — WenZi">
  <div class="min-h-screen bg-slate-50 text-slate-950">
    <Header activePage="community" />

    <main class="px-4 py-6 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-[1280px]">
        <div class="grid gap-4 md:grid-cols-[1fr_320px] lg:grid-cols-[280px_1fr_320px]">

          <aside class="hidden lg:block space-y-4">
            <section class="rounded-[28px] bg-white border border-slate-200/80 p-5 shadow-sm">
              <div class="mb-4 flex items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-rose-100 text-rose-600">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                    <path d="M12 2c0 0-4 4-4 8a4 4 0 0 0 8 0c0-1-.3-2-.8-2.9C15 8.9 15 11 13 12c0-2-1-4-1-4z"/>
                    <path d="M12 22a6 6 0 0 0 6-6c0-3-2-4.5-3-5.5 0 1.5-1 3-2 3.5C12.3 13.2 10 14 9 16a4 4 0 0 0 3 4z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-900">Câu hỏi được quan tâm</p>
                  <p class="text-xs text-slate-500">Những topic đang nóng nhất trong cộng đồng.</p>
                </div>
              </div>
              <ol class="space-y-3">
                {HOT_QUESTIONS.map((question, index) => (
                  <li class="flex items-start gap-3 rounded-3xl border border-slate-200/80 bg-slate-50 px-4 py-3 transition hover:border-slate-300 hover:bg-white">
                    <span class={`mt-1 inline-flex h-7 w-7 items-center justify-center rounded-2xl ${index < 3 ? 'bg-sky-600 text-white' : 'bg-slate-200 text-slate-700'} text-xs font-semibold`}>
                      {index + 1}
                    </span>
                    <p class="text-sm leading-6 text-slate-700">{question}</p>
                  </li>
                ))}
              </ol>
            </section>

            <section class="rounded-[28px] bg-white border border-slate-200/80 p-5 shadow-sm">
              <div class="mb-4 flex items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-100 text-slate-700">
                  <Grid class="h-5 w-5" />
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-900">Thể loại</p>
                  <p class="text-xs text-slate-500">Chọn chủ đề bạn quan tâm.</p>
                </div>
              </div>
              <div class="grid gap-2">
                {CATEGORIES.map((category) => {
                  const Icon = ICONS[category.icon];
                  return (
                    <button class="flex items-center gap-3 rounded-3xl border border-slate-200/80 bg-slate-50 px-4 py-3 text-left text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-white" type="button" data-cat={category.name}>
                      <span class="inline-flex h-9 w-9 items-center justify-center rounded-2xl bg-slate-100 text-slate-700">
                        <Icon class="h-5 w-5" />
                      </span>
                      <span>{category.name}</span>
                    </button>
                  );
                })}
              </div>
            </section>
          </aside>

          <section class="space-y-4">
            <div class="rounded-[32px] bg-white border border-slate-200/80 p-5 shadow-sm transition hover:shadow-md">
              <div class="flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-3xl bg-slate-900 text-sm font-bold text-white">{currentUser.avatar}</div>
                <button id="create-post-btn" type="button" class="flex-1 rounded-full border border-slate-200/80 bg-slate-50 px-4 py-3 text-left text-sm text-slate-500 transition hover:border-slate-300 hover:bg-white">
                  {currentUser.name}, bạn đang thắc mắc điều gì?
                </button>
              </div>
            </div>

            <div class="inline-flex flex-wrap gap-2 rounded-full border border-slate-200/80 bg-white p-2 shadow-sm">
              {FILTERS.map((filter, index) => (
                <button type="button" class={`filter-tab rounded-full px-4 py-2 text-sm font-semibold transition ${index === 0 ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100'}`} data-filter={filter}>
                  {filter}
                </button>
              ))}
            </div>

            <div id="post-list" class="space-y-4">
              {POSTS.map((post) => (
                <article class={`rounded-[28px] border border-slate-200/80 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md ${post.pinned ? 'ring-1 ring-sky-200' : ''}`} data-id={post.id}>
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <div class="flex h-12 w-12 items-center justify-center rounded-3xl text-sm font-bold text-white" style={`background:${post.color}`}>
                        {post.avatar}
                      </div>
                      <div class="min-w-0">
                        <p class="text-sm font-semibold text-slate-950">{post.name}</p>
                        <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-slate-500">
                          {post.role && <span class={`rounded-full px-2 py-1 ${post.role === 'BTV' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-700'}`}>{post.role}</span>}
                          <span>{post.time}</span>
                        </div>
                      </div>
                    </div>
                    <div class="flex items-center gap-2 text-xs text-slate-500">
                      {post.pinned && (
                        <span class="inline-flex items-center gap-1 rounded-full bg-sky-100 px-3 py-1 text-sky-700">
                          <Pin class="h-3.5 w-3.5" /> Ghim
                        </span>
                      )}
                      <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">{post.category}</span>
                    </div>
                  </div>
                  <h2 class="mt-5 text-lg font-extrabold leading-7 text-slate-950 transition hover:text-sky-600">{post.title}</h2>
                  <p class="mt-3 text-sm leading-7 text-slate-600">{post.content}</p>
                  <div class="mt-5 flex flex-wrap items-center gap-3 border-t border-slate-200/80 pt-4 text-sm text-slate-600">
                    <button class={`post-stat inline-flex items-center gap-2 rounded-full px-3 py-2 transition ${post.liked ? 'bg-rose-50 text-rose-600' : 'hover:bg-slate-100'}`} type="button" data-like={post.id}>
                      <Heart class="h-4 w-4" />
                      <span>{post.likes}</span>
                    </button>
                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 hover:bg-slate-100">
                      <MessageCircle class="h-4 w-4" />
                      <span>{post.comments}</span>
                    </span>
                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 hover:bg-slate-100">
                      <Eye class="h-4 w-4" />
                      <span>{post.views}</span>
                    </span>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <aside class="hidden md:block space-y-4">
            <section class="rounded-[28px] bg-white border border-slate-200/80 p-5 shadow-sm">
              <label class="relative block text-slate-900">
                <span class="sr-only">Tìm kiếm bài viết</span>
                <Search class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" />
                <input id="post-search" type="search" placeholder="Tìm kiếm bài viết..." class="w-full rounded-3xl border border-slate-200/80 bg-slate-50/90 py-3 pl-12 pr-4 text-sm text-slate-700 outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-100" />
              </label>
            </section>

            <section class="rounded-[28px] bg-white border border-slate-200/80 p-5 shadow-sm">
              <div class="mb-5 flex items-center gap-3">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-amber-100 text-amber-700">
                  <Crown class="h-5 w-5" />
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-950">Vinh danh</p>
                  <p class="text-xs text-slate-500">Top thành viên tương tác cao.</p>
                </div>
              </div>
              <div class="mb-5 flex flex-wrap gap-2">
                {['Tuần', 'Tháng', 'Năm'].map((period, index) => (
                  <button type="button" class={`lb-tab min-w-[88px] rounded-full border px-4 py-2 text-center text-sm font-semibold transition ${index === 0 ? 'bg-slate-900 text-white' : 'border-slate-200 bg-slate-50 text-slate-600 hover:bg-slate-100'}`} data-period={period.toLowerCase()}>
                    {period}
                  </button>
                ))}
              </div>
              <div id="podium" class="mb-4 flex items-end justify-center gap-3"></div>
              <div id="lb-list" class="space-y-3"></div>
            </section>
          </aside>
        </div>
      </div>
    </main>

    <div id="modal-post" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/40 p-4 backdrop-blur-sm">
      <div class="w-full max-w-xl rounded-[30px] bg-white p-6 shadow-2xl">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="text-lg font-bold text-slate-950">Đăng bài mới</p>
            <p class="mt-1 text-sm text-slate-500">Chia sẻ thắc mắc hoặc kiến thức của bạn với cộng đồng.</p>
          </div>
          <button id="modal-post-close" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 text-slate-600 transition hover:border-slate-300 hover:text-slate-900">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
              <path d="M18 6 6 18M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="grid gap-4">
          <input id="new-post-title" type="text" placeholder="Tiêu đề bài viết..." class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-100" maxlength="120" />
          <textarea id="new-post-content" rows="5" placeholder="Nội dung bài viết..." class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-100 resize-none" maxlength="1000"></textarea>
          <select id="new-post-cat" class="w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
            {CATEGORIES.map((category) => (
              <option value={category.name}>{category.name}</option>
            ))}
          </select>
          <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <button id="modal-post-cancel" type="button" class="rounded-3xl border border-slate-200 bg-slate-50 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-100">Hủy</button>
            <button id="modal-post-submit" type="button" class="rounded-3xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">Đăng bài</button>
          </div>
        </div>
      </div>
    </div>

    <footer class="border-t border-slate-200 bg-slate-50 py-6 text-center text-sm text-slate-500">
      WenZi © 2026 — MIT License
    </footer>
  </div>
</BaseLayout>

<script type="module">
  const POSTS_DATA = ${JSON.stringify(POSTS)};
  const CATEGORIES_DATA = ${JSON.stringify(CATEGORIES)};
  const LB_DATA = ${JSON.stringify(LEADERBOARD)};

  let activeCategory = '';
  let filteredPosts = [...POSTS_DATA];

  const postList = document.getElementById('post-list');
  const postSearch = document.getElementById('post-search');
  const createPostBtn = document.getElementById('create-post-btn');
  const modalPost = document.getElementById('modal-post');
  const modalClose = document.getElementById('modal-post-close');
  const modalCancel = document.getElementById('modal-post-cancel');
  const modalSubmit = document.getElementById('modal-post-submit');
  const newTitle = document.getElementById('new-post-title');
  const newContent = document.getElementById('new-post-content');
  const newCat = document.getElementById('new-post-cat');
  const filterButtons = Array.from(document.querySelectorAll('.filter-tab'));
  const categoryButtons = Array.from(document.querySelectorAll('[data-cat]'));
  const lbTabs = Array.from(document.querySelectorAll('.lb-tab'));

  const posts = POSTS_DATA;
  const leaderboard = LB_DATA;
  const categories = CATEGORIES_DATA;

  function fmtNumber(value) {
    return value >= 1000 ? `${(value / 1000).toFixed(1)}k` : String(value);
  }

  function renderPosts(postsToRender) {
    if (!postList) return;
    if (postsToRender.length === 0) {
      postList.innerHTML = `<div class="rounded-[28px] border border-slate-200/80 bg-white p-8 text-center text-sm text-slate-500 shadow-sm">Không tìm thấy bài viết phù hợp.</div>`;
      return;
    }

    postList.innerHTML = postsToRender
      .map((post) => `
      <article class="rounded-[28px] border border-slate-200/80 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md ${post.pinned ? 'ring-1 ring-sky-200' : ''}" data-id="${post.id}">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="flex items-center gap-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-3xl text-sm font-bold text-white" style="background: ${post.color}">${post.avatar}</div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-slate-950">${post.name}</p>
              <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-slate-500">
                ${post.role ? `<span class="rounded-full px-2 py-1 ${post.role === 'BTV' ? 'bg-amber-100 text-amber-800' : 'bg-slate-100 text-slate-700'}">${post.role}</span>` : ''}
                <span>${post.time}</span>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-2 text-xs text-slate-500">
            ${post.pinned ? `<span class="inline-flex items-center gap-1 rounded-full bg-sky-100 px-3 py-1 text-sky-700"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M6 2h12v4H6z"></path><path d="M12 6v16"></path></svg>Ghim</span>` : ''}
            <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">${post.category}</span>
          </div>
        </div>
        <h2 class="mt-5 text-lg font-extrabold leading-7 text-slate-950 transition hover:text-sky-600">${post.title}</h2>
        <p class="mt-3 text-sm leading-7 text-slate-600">${post.content}</p>
        <div class="mt-5 flex flex-wrap items-center gap-3 border-t border-slate-200/80 pt-4 text-sm text-slate-600">
          <button class="inline-flex items-center gap-2 rounded-full px-3 py-2 transition ${post.liked ? 'bg-rose-50 text-rose-600' : 'hover:bg-slate-100'}" data-like="${post.id}" type="button">
            <svg viewBox="0 0 24 24" fill="${post.liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"> <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 1 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span>${fmtNumber(post.likes)}</span>
          </button>
          <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 hover:bg-slate-100">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>${fmtNumber(post.comments)}</span>
          </span>
          <span class="inline-flex items-center gap-2 rounded-full px-3 py-2 hover:bg-slate-100">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <span>${fmtNumber(post.views)}</span>
          </span>
        </div>
      </article>`
      )
      .join('');

    postList.querySelectorAll('[data-like]').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        const id = Number(button.dataset.like);
        const item = posts.find((post) => post.id === id);
        if (!item) return;
        item.liked = !item.liked;
        item.likes += item.liked ? 1 : -1;
        renderPosts(filteredPosts);
      });
    });
  }

  function updateFilters(filterLabel) {
    filterButtons.forEach((button) => button.classList.toggle('bg-slate-900', button.dataset.filter === filterLabel));
    filterButtons.forEach((button) => button.classList.toggle('text-white', button.dataset.filter === filterLabel));
    filterButtons.forEach((button) => button.classList.toggle('text-slate-600', button.dataset.filter !== filterLabel));

    if (filterLabel === 'Tất cả') {
      filteredPosts = [...posts];
    } else if (filterLabel === 'Yêu thích') {
      filteredPosts = posts.filter((post) => post.liked);
    } else if (filterLabel === 'Quan tâm') {
      filteredPosts = posts.filter((post) => post.likes >= 150 || post.pinned);
    } else if (filterLabel === 'BTV lựa chọn') {
      filteredPosts = posts.filter((post) => post.role === 'BTV');
    } else {
      filteredPosts = [...posts];
    }
    if (activeCategory) {
      filteredPosts = filteredPosts.filter((post) => post.category === activeCategory);
    }
    renderPosts(filteredPosts);
  }

  function renderLeaderboard(period) {
    const periodKey = period || 'tuần';
    const items = leaderboard[periodKey] || leaderboard['tuần'];
    const podiumContainer = document.getElementById('podium');
    const listContainer = document.getElementById('lb-list');
    if (!podiumContainer || !listContainer) return;
    const top3 = items.slice(0, 3);
    const rest = items.slice(3);
    const slots = [top3[1], top3[0], top3[2]];
    const heights = ['52px', '72px', '44px'];
    const crowns = ['','👑',''];

    podiumContainer.innerHTML = slots
      .map((entry, index) => `
        <div class="flex w-full flex-col items-center gap-3 text-center">
          <div class="relative flex h-12 w-12 items-center justify-center rounded-full text-sm font-semibold text-white" style="background:${entry.color || '#0f172a'};">
            ${crowns[index] ? `<span class="absolute -top-3 text-[0.7rem]">${crowns[index]}</span>` : ''}
            ${entry.avatar}
          </div>
          <span class="max-w-[92px] truncate text-sm font-semibold text-slate-900">${entry.name}</span>
          <span class="text-xs text-slate-500">${entry.score >= 1000 ? `${(entry.score / 1000).toFixed(1)}k` : entry.score} điểm</span>
          <div class="flex h-12 w-full items-end justify-center rounded-t-3xl text-lg font-black text-white" style="background:${entry.color || '#0f172a'}; height:${heights[index]};">${entry.rank}</div>
        </div>`)
      .join('');

    listContainer.innerHTML = rest
      .map((entry) => `
        <div class="flex items-center gap-3 rounded-3xl px-3 py-2 transition hover:bg-slate-100">
          <span class="min-w-[24px] text-xs font-bold text-slate-500">${entry.rank}</span>
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-sm font-bold text-slate-700">${entry.avatar}</span>
          <span class="min-w-0 flex-1 truncate text-sm font-semibold text-slate-900">${entry.name}</span>
          <span class="text-xs font-semibold text-slate-500">${entry.score >= 1000 ? `${(entry.score / 1000).toFixed(1)}k` : entry.score}</span>
        </div>`)
      .join('');
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      updateFilters(button.dataset.filter || 'Tất cả');
    });
  });

  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const category = button.dataset.cat || '';
      if (activeCategory === category) {
        activeCategory = '';
        categoryButtons.forEach((btn) => btn.classList.remove('bg-slate-100'));
      } else {
        activeCategory = category;
        categoryButtons.forEach((btn) => btn.classList.remove('bg-slate-100'));
        button.classList.add('bg-slate-100');
      }
      filteredPosts = posts.filter((post) => (!activeCategory || post.category === activeCategory));
      renderPosts(filteredPosts);
    });
  });

  postSearch?.addEventListener('input', (event) => {
    const query = (event.target.value || '').trim().toLowerCase();
    filteredPosts = posts.filter((post) => {
      const match = [post.title, post.content, post.name, post.category].some((value) => value.toLowerCase().includes(query));
      return query ? match : true;
    });
    if (activeCategory) {
      filteredPosts = filteredPosts.filter((post) => post.category === activeCategory);
    }
    renderPosts(filteredPosts);
  });

  createPostBtn?.addEventListener('click', () => modalPost?.classList.remove('hidden'));
  modalClose?.addEventListener('click', () => modalPost?.classList.add('hidden'));
  modalCancel?.addEventListener('click', () => modalPost?.classList.add('hidden'));

  modalSubmit?.addEventListener('click', () => {
    const titleValue = newTitle.value.trim();
    const contentValue = newContent.value.trim();
    const categoryValue = newCat.value;
    if (!titleValue) {
      newTitle.focus();
      return;
    }
    const newPost = {
      id: Date.now(),
      pinned: false,
      avatar: 'BN',
      name: 'Bạn',
      role: '',
      time: 'Vừa xong',
      category: categoryValue,
      title: titleValue,
      content: contentValue || 'Mình đang cần thảo luận thêm về chủ đề này.',
      likes: 0,
      comments: 0,
      views: 1,
      color: '#0f172a',
      liked: false,
    };
    posts.unshift(newPost);
    filteredPosts = [...posts];
    modalPost?.classList.add('hidden');
    newTitle.value = '';
    newContent.value = '';
    renderPosts(filteredPosts);
  });

  modalPost?.addEventListener('click', (event) => {
    if (event.target === modalPost) {
      modalPost.classList.add('hidden');
    }
  });

  updateFilters('Tất cả');
  renderLeaderboard('tuần');
  lbTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      lbTabs.forEach((item) => item.classList.remove('bg-slate-900', 'text-white'));
      lbTabs.forEach((item) => item.classList.add('bg-slate-50', 'text-slate-600'));
      tab.classList.remove('bg-slate-50', 'text-slate-600');
      tab.classList.add('bg-slate-900', 'text-white');
      renderLeaderboard(tab.dataset.period || 'tuần');
    });
  });
</script>
