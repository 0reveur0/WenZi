---
// Ô tìm kiếm — chưa có chức năng (sẽ tích hợp sau)
---

<form class="search-form" role="search" aria-label="Tìm kiếm từ vựng Hán Việt">
  <div class="search-wrapper">
    <span class="search-icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.35-4.35"/>
      </svg>
    </span>

    <input
      type="search"
      name="q"
      id="search-input"
      class="search-input"
      placeholder="Nhập chữ Hán, Hán Việt hoặc nghĩa..."
      autocomplete="off"
      spellcheck="false"
      aria-label="Từ khóa tìm kiếm"
    />

    <kbd class="search-hint" aria-hidden="true">↵</kbd>
  </div>

  <p class="search-caption">
    Tìm theo chữ Hán <span class="sep">·</span> pinyin <span class="sep">·</span> Hán Việt <span class="sep">·</span> nghĩa tiếng Việt
  </p>
</form>

<style>
  .search-form {
    width: 100%;
    max-width: 580px;
    margin: 0 auto;
  }

  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }

  .search-wrapper:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 15%, transparent),
                var(--shadow-md);
  }

  .search-icon {
    display: flex;
    align-items: center;
    padding: 0 14px 0 18px;
    color: var(--color-text-muted);
    pointer-events: none;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--color-text);
    font-size: 1.05rem;
    font-family: var(--font-sans);
    padding: 16px 0;
    min-width: 0;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.7;
  }

  /* Ẩn icon X mặc định trên Safari */
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 14px;
    padding: 3px 7px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .search-wrapper:focus-within .search-hint {
    opacity: 0;
    pointer-events: none;
  }

  .search-caption {
    margin-top: 10px;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .sep {
    margin: 0 4px;
    opacity: 0.4;
  }
</style>
