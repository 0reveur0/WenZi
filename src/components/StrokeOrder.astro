---
/**
 * StrokeOrder — Hiển thị thứ tự nét viết với hanzi-writer
 * Chỉ render nếu simplified có ít nhất 1 ký tự Hán.
 */
interface Props {
  simplified: string;
}

const { simplified } = Astro.props;

// Lọc chỉ lấy ký tự Hán (bỏ số, dấu câu, khoảng trắng)
const hanziChars = [...simplified]
  .filter(c => /[\u4e00-\u9fff\u3400-\u4dbf\uf900-\ufaff]/.test(c))
  .slice(0, 4); // Giới hạn 4 ký tự để giao diện gọn

const hasHanzi = hanziChars.length > 0;
---

{hasHanzi && (
  <div class="stroke-card" id="stroke-section">
    <div class="stroke-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="stroke-icon" aria-hidden="true">
        <path d="M12 20h9"/>
        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
      <span class="stroke-title">Thứ tự nét viết</span>
      <span class="stroke-badge">{hanziChars.length} ký tự</span>
    </div>

    <div class="stroke-grid" data-count={hanziChars.length}>
      {hanziChars.map((char, i) => (
        <div class="stroke-item" data-item={i}>

          <!-- Khung vẽ -->
          <div class="stroke-canvas-wrap">
            <!-- Loading spinner (ẩn sau khi writer khởi tạo) -->
            <div class="stroke-loading" id={`stroke-loading-${i}`} aria-label="Đang tải...">
              <svg class="spin" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="#94a3b8" stroke-width="2" stroke-linecap="round">
                <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
              </svg>
            </div>

            <!-- Mục tiêu để HanziWriter render vào -->
            <div
              id={`hanzi-target-${i}`}
              class="stroke-writer"
              data-char={char}
              data-idx={i}
              aria-label={`Nét viết: ${char}`}
            ></div>

            <!-- Lớp overlay khi quiz đang chạy -->
            <div class="stroke-quiz-overlay" id={`quiz-overlay-${i}`} hidden>
              <span class="quiz-prompt">Hãy vẽ nét theo đúng thứ tự!</span>
            </div>
          </div>

          <!-- Ký tự label -->
          <div class="stroke-char-label" lang="zh">{char}</div>

          <!-- Nút điều khiển -->
          <div class="stroke-controls" role="group" aria-label="Điều khiển nét viết">

            <!-- Nút Phát lại -->
            <button
              class="stroke-btn"
              id={`btn-play-${i}`}
              data-action="play"
              data-idx={i}
              title="Phát lại"
              aria-label="Phát lại thứ tự nét"
              type="button"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <polygon points="5 3 19 12 5 21 5 3"/>
              </svg>
              <span class="btn-label">Phát</span>
            </button>

            <!-- Nút Lặp liên tục -->
            <button
              class="stroke-btn"
              id={`btn-loop-${i}`}
              data-action="loop"
              data-idx={i}
              title="Lặp liên tục"
              aria-label="Lặp liên tục thứ tự nét"
              type="button"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="17 1 21 5 17 9"/>
                <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
                <polyline points="7 23 3 19 7 15"/>
                <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
              </svg>
              <span class="btn-label">Lặp</span>
            </button>

            <!-- Nút Tập viết (Quiz) -->
            <button
              class="stroke-btn"
              id={`btn-quiz-${i}`}
              data-action="quiz"
              data-idx={i}
              title="Tập viết"
              aria-label="Tập viết thử"
              type="button"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
              <span class="btn-label">Viết</span>
            </button>

          </div>

          <!-- Phản hồi quiz -->
          <div class="stroke-quiz-feedback" id={`quiz-feedback-${i}`} aria-live="polite"></div>

        </div>
      ))}
    </div>
  </div>
)}

<style>
  /* ── Card ──────────────────────────────────────────────────────────── */
  .stroke-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Header ─────────────────────────────────────────────────────────── */
  .stroke-header {
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .stroke-icon { color: var(--color-text-muted); flex-shrink: 0; }
  .stroke-title {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--color-text-muted);
    flex: 1;
  }
  .stroke-badge {
    font-size: .68rem;
    font-weight: 600;
    background: var(--color-primary-dim);
    color: var(--color-primary);
    padding: .15rem .55rem;
    border-radius: 999px;
  }

  /* ── Grid of characters ──────────────────────────────────────────────── */
  .stroke-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    justify-content: center;
  }
  .stroke-grid[data-count="1"] .stroke-item { width: 220px; }
  .stroke-grid[data-count="2"] .stroke-item { width: 200px; }
  .stroke-grid[data-count="3"] .stroke-item { width: 180px; }
  .stroke-grid[data-count="4"] .stroke-item { width: 160px; }

  .stroke-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .6rem;
  }

  /* ── Canvas wrapper ──────────────────────────────────────────────────── */
  .stroke-canvas-wrap {
    position: relative;
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    background: #fafbfd;
    overflow: hidden;
    /* Size is set dynamically by JS to match the writer */
    width: 200px;
    height: 200px;
    flex-shrink: 0;
  }
  .stroke-grid[data-count="3"] .stroke-canvas-wrap,
  .stroke-grid[data-count="4"] .stroke-canvas-wrap {
    width: 170px;
    height: 170px;
  }

  .stroke-writer {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .stroke-writer svg {
    width: 100% !important;
    height: 100% !important;
  }

  /* Loading spinner */
  .stroke-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafbfd;
    border-radius: 14px;
    z-index: 2;
    transition: opacity .25s;
  }
  .stroke-loading.hidden { opacity: 0; pointer-events: none; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin .9s linear infinite; }

  /* Quiz overlay hint */
  .stroke-quiz-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(43,76,126,.12));
    padding: .5rem;
    text-align: center;
    pointer-events: none;
  }
  .quiz-prompt {
    font-size: .62rem;
    font-weight: 600;
    color: var(--color-primary);
    background: rgba(255,255,255,.88);
    padding: .2rem .5rem;
    border-radius: 6px;
  }

  /* ── Char label ──────────────────────────────────────────────────────── */
  .stroke-char-label {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-text);
    line-height: 1;
  }

  /* ── Controls ────────────────────────────────────────────────────────── */
  .stroke-controls {
    display: flex;
    gap: .4rem;
  }

  .stroke-btn {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    padding: .45rem .75rem;
    border-radius: 999px;
    border: 1.5px solid var(--color-border);
    background: #f8fafc;
    color: var(--color-text-muted);
    font-size: .72rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
    white-space: nowrap;
    user-select: none;
  }
  .stroke-btn:hover {
    background: var(--color-primary-dim);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .stroke-btn:active { transform: scale(.95); }
  .stroke-btn.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .stroke-btn.quiz-active {
    background: #fef3c7;
    border-color: #f59e0b;
    color: #d97706;
  }
  .btn-label { font-size: .7rem; }

  /* ── Quiz feedback ───────────────────────────────────────────────────── */
  .stroke-quiz-feedback {
    min-height: 1.25rem;
    font-size: .75rem;
    font-weight: 600;
    text-align: center;
    transition: color .2s;
  }
  .stroke-quiz-feedback.correct { color: #16a34a; }
  .stroke-quiz-feedback.mistake { color: #dc2626; }
  .stroke-quiz-feedback.done    { color: var(--color-primary); }

  /* ── Dark mode ───────────────────────────────────────────────────────── */
  @media (prefers-color-scheme: dark) {
    .stroke-canvas-wrap { background: #1e293b; border-color: #334155; }
    .stroke-loading      { background: #1e293b; }
    .stroke-btn          { background: #1e293b; border-color: #334155; }
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .stroke-card { padding: 1.25rem 1.25rem; }
    .stroke-grid[data-count="1"] .stroke-canvas-wrap,
    .stroke-grid[data-count="2"] .stroke-canvas-wrap { width: 160px; height: 160px; }
    .stroke-grid[data-count="3"] .stroke-canvas-wrap,
    .stroke-grid[data-count="4"] .stroke-canvas-wrap { width: 140px; height: 140px; }
  }
</style>

<script>
  import HanziWriter from 'hanzi-writer';

  // ── Kích thước writer theo số ký tự ──────────────────────────────────
  function getWriterSize(): number {
    const grid = document.querySelector<HTMLElement>('.stroke-grid');
    const count = parseInt(grid?.dataset.count ?? '1');
    const mobile = window.innerWidth < 480;
    if (mobile) return count <= 2 ? 158 : 138;
    return count <= 2 ? 198 : count === 3 ? 168 : 158;
  }

  // ── State mỗi writer ──────────────────────────────────────────────────
  type WriterState = 'idle' | 'animating' | 'looping' | 'quizzing';
  interface WriterEntry {
    writer: InstanceType<typeof HanziWriter>;
    state: WriterState;
    char: string;
    idx: number;
  }
  const writers = new Map<number, WriterEntry>();

  // ── Khởi tạo tất cả writers ──────────────────────────────────────────
  function initWriters() {
    const size = getWriterSize();
    const targets = document.querySelectorAll<HTMLElement>('[data-idx][data-char]');

    targets.forEach(el => {
      const char = el.dataset.char!;
      const idx  = parseInt(el.dataset.idx!);
      const loadingEl = document.getElementById(`stroke-loading-${idx}`);

      const writer = HanziWriter.create(el, char, {
        width:               size,
        height:              size,
        padding:             Math.round(size * 0.04),
        strokeColor:         '#2b4c7e',
        radicalColor:        '#2b4c7e',
        outlineColor:        '#e2e8f0',
        drawingColor:        '#2b4c7e',
        drawingWidth:        4,
        strokeAnimationSpeed: 1.2,
        delayBetweenStrokes: 150,
        delayBetweenLoops:   800,
        showCharacter:       true,
        showOutline:         true,
        renderer:            'svg',
        // Callback khi data stroke tải thành công → ẩn spinner, auto-play
        onLoadCharDataSuccess() {
          loadingEl?.classList.add('hidden');
          const entry = writers.get(idx);
          if (entry && entry.state === 'idle') {
            setTimeout(() => {
              if (writers.get(idx)?.state === 'idle') {
                writer.animateCharacter();
                entry.state = 'animating';
                // Reset state sau khi animation xong (ước tính ~3-5s)
                setTimeout(() => {
                  if (writers.get(idx)?.state === 'animating') {
                    writers.get(idx)!.state = 'idle';
                  }
                }, 5000);
              }
            }, 150);
          }
        },
        // Callback khi không tải được data (ký tự không có trong DB)
        onLoadCharDataError() {
          if (loadingEl) {
            loadingEl.innerHTML = '<span style="font-size:1.4rem;color:#94a3b8;line-height:1" title="Không có dữ liệu nét viết">?</span>';
          }
        },
      });

      writers.set(idx, { writer, state: 'idle', char, idx });
    });
  }

  // ── Cập nhật trạng thái nút ───────────────────────────────────────────
  function setButtonState(idx: number, active: 'none' | 'loop' | 'quiz') {
    document.getElementById(`btn-loop-${idx}`)?.classList.toggle('active',      active === 'loop');
    document.getElementById(`btn-quiz-${idx}`)?.classList.toggle('quiz-active', active === 'quiz');
    const overlay = document.getElementById(`quiz-overlay-${idx}`);
    if (overlay) overlay.hidden = (active !== 'quiz');
  }

  function setFeedback(idx: number, msg: string, cls: 'correct' | 'mistake' | 'done' | '') {
    const fb = document.getElementById(`quiz-feedback-${idx}`);
    if (!fb) return;
    fb.textContent = msg;
    fb.className   = 'stroke-quiz-feedback' + (cls ? ` ${cls}` : '');
  }

  // ── Xử lý click nút ──────────────────────────────────────────────────
  document.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-action][data-idx]');
    if (!btn) return;

    const action = btn.dataset.action!;
    const idx    = parseInt(btn.dataset.idx!);
    const entry  = writers.get(idx);
    if (!entry) return;
    const { writer } = entry;

    // ── Phát lại một lần ────────────────────────────────────────────
    if (action === 'play') {
      if (entry.state === 'quizzing')  { writer.cancelQuiz();      setFeedback(idx, '', ''); }
      if (entry.state === 'looping')   { writer.cancelAnimation(); }
      setButtonState(idx, 'none');
      entry.state = 'animating';
      writer.animateCharacter({ onComplete: () => { entry.state = 'idle'; } });
    }

    // ── Lặp liên tục ─────────────────────────────────────────────────
    else if (action === 'loop') {
      if (entry.state === 'looping') {
        writer.cancelAnimation();
        writer.showCharacter();
        entry.state = 'idle';
        setButtonState(idx, 'none');
      } else {
        if (entry.state === 'quizzing') { writer.cancelQuiz(); setFeedback(idx, '', ''); }
        else if (entry.state === 'animating') { writer.cancelAnimation(); }
        entry.state = 'looping';
        setButtonState(idx, 'loop');
        writer.loopCharacterAnimation();
      }
    }

    // ── Tập viết (Quiz) ───────────────────────────────────────────────
    else if (action === 'quiz') {
      if (entry.state === 'quizzing') {
        // Thoát quiz → hiện lại ký tự
        writer.cancelQuiz();
        writer.showCharacter();
        entry.state = 'idle';
        setButtonState(idx, 'none');
        setFeedback(idx, '', '');
      } else {
        if (entry.state === 'looping' || entry.state === 'animating') {
          writer.cancelAnimation();
        }
        entry.state = 'quizzing';
        setButtonState(idx, 'quiz');
        setFeedback(idx, 'Hãy vẽ nét đầu tiên…', '');

        writer.quiz({
          showOutline:    true,
          highlightColor: '#60a5fa',
          onMistake(strokeData) {
            setFeedback(idx,
              `Nét ${strokeData.strokeNum + 1}: Thử lại! (${strokeData.mistakesOnStroke} lần)`,
              'mistake');
          },
          onCorrectStroke(strokeData) {
            const rem = strokeData.totalStrokeCount - strokeData.strokeNum - 1;
            setFeedback(idx,
              rem > 0
                ? `✓ Nét ${strokeData.strokeNum + 1}! Còn ${rem} nét nữa.`
                : '✓ Nét cuối cùng!',
              'correct');
          },
          onComplete(summary) {
            entry.state = 'idle';
            setButtonState(idx, 'none');
            setFeedback(idx,
              summary.totalMistakes === 0
                ? '🎉 Hoàn hảo! Không có lỗi nào!'
                : `✅ Hoàn thành! ${summary.totalMistakes} lỗi tổng cộng.`,
              'done');
            setTimeout(() => setFeedback(idx, '', ''), 4000);
          },
        });
      }
    }
  });

  // ── Init ──────────────────────────────────────────────────────────────
  initWriters();
</script>
