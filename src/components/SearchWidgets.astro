---
/**
 * SearchWidgets — Từ khóa hot + Lịch sử tìm kiếm
 * Đặt trong #history-section nên tự ẩn khi đang search, hiện khi idle.
 */

const HOT_KEYWORDS = [
  { word: '划船', note: 'chèo thuyền' },
  { word: '真实', note: 'thật sự' },
  { word: '爸爸', note: 'bố, cha' },
  { word: '粽子', note: 'bánh chưng' },
  { word: '责任', note: 'trách nhiệm' },
  { word: '新闻', note: 'tin tức' },
  { word: '夏天', note: 'mùa hè' },
  { word: '关心', note: 'quan tâm' },
  { word: '报道', note: 'đưa tin' },
  { word: '记者', note: 'phóng viên' },
  { word: '朋友', note: 'bạn bè' },
  { word: '快乐', note: 'vui vẻ' },
];
---

<div class="sw-grid">

  <!-- ── Card 1: Từ khóa hot ─────────────────────────────────────────────── -->
  <div class="sw-card">
    <div class="sw-card-header">
      <div class="sw-title-group">
        <span class="sw-fire-icon" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2c0 0-4 4-4 8a4 4 0 0 0 8 0c0-1-.3-2-.8-2.9C15 8.9 15 11 13 12c0-2-1-4-1-4z"/>
            <path d="M12 22a6 6 0 0 0 6-6c0-3-2-4.5-3-5.5 0 1.5-1 3-2 3.5C12.3 13.2 10 14 9 16a4 4 0 0 0 3 4z"/>
          </svg>
        </span>
        <h2 class="sw-title">Từ khóa hot</h2>
      </div>
      <span class="sw-badge">{HOT_KEYWORDS.length}</span>
    </div>

    <div class="sw-tags" role="list" aria-label="Danh sách từ khóa hot">
      {HOT_KEYWORDS.map(k => (
        <button
          class="sw-tag sw-tag--hot"
          type="button"
          role="listitem"
          data-query={k.word}
          title={k.note}
          aria-label={`${k.word} — ${k.note}`}
        >
          <span class="sw-tag-zh" lang="zh">{k.word}</span>
          <span class="sw-tag-vi">{k.note}</span>
        </button>
      ))}
    </div>
  </div>

  <!-- ── Card 2: Lịch sử tìm kiếm ──────────────────────────────────────── -->
  <div class="sw-card">
    <div class="sw-card-header">
      <div class="sw-title-group">
        <span class="sw-clock-icon" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </span>
        <h2 class="sw-title">Lịch sử</h2>
      </div>
      <button class="sw-clear-btn" id="sw-clear-hist" type="button"
        title="Xóa lịch sử" aria-label="Xóa lịch sử tìm kiếm" hidden>
        Xóa tất cả
      </button>
    </div>

    <!-- Tags populated by JS -->
    <div class="sw-tags" id="sw-hist-tags" role="list"
      aria-label="Lịch sử tìm kiếm" aria-live="polite"></div>

    <!-- Empty state (shown when no history) -->
    <div class="sw-empty" id="sw-hist-empty">
      <div class="sw-empty-icon" aria-hidden="true">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" opacity=".5"/>
          <path d="m21 21-4.35-4.35" opacity=".5"/>
          <path d="M11 8v3l2 2" stroke-width="1.6"/>
          <circle cx="11" cy="11" r="1" fill="currentColor" opacity="0"/>
        </svg>
      </div>
      <p class="sw-empty-text">Chưa có lịch sử</p>
      <p class="sw-empty-sub">Tìm kiếm để lưu tự động</p>
    </div>
  </div>

</div>

<!-- ─────────────────── STYLES ─────────────────────────────────────────── -->
<style>
  /* 2-column grid: stack on mobile, side-by-side on tablet+ */
  .sw-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: .75rem;
    margin-bottom: 1.25rem;
  }
  @media (min-width: 600px) {
    .sw-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Card */
  .sw-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    padding: 1.25rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: .9rem;
    min-height: 170px;
  }

  /* Header */
  .sw-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
  }
  .sw-title-group {
    display: flex;
    align-items: center;
    gap: .4rem;
  }
  .sw-fire-icon  { color: #ef4444; display: flex; align-items: center; }
  .sw-clock-icon { color: var(--color-text-muted); display: flex; align-items: center; }
  .sw-title {
    font-size: .93rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .sw-badge {
    font-size: .68rem;
    font-weight: 700;
    background: var(--color-primary);
    color: #fff;
    border-radius: 999px;
    padding: .1rem .45rem;
    min-width: 20px;
    text-align: center;
    line-height: 1.5;
  }
  .sw-clear-btn {
    font-size: .72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: none;
    border: 1.5px solid var(--color-border);
    border-radius: 6px;
    padding: .2rem .55rem;
    cursor: pointer;
    transition: color .15s, border-color .15s;
    white-space: nowrap;
  }
  .sw-clear-btn:hover { color: #ef4444; border-color: #ef4444; }

  /* Tags wrapper */
  .sw-tags {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
  }

  /* Tag base */
  :global(.sw-tag) {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .35rem .75rem;
    border-radius: 999px;
    font-size: .82rem;
    font-weight: 500;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: all .15s;
    line-height: 1.2;
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
  }
  :global(.sw-tag:active) { transform: scale(.94); }

  /* Hot keyword tag */
  :global(.sw-tag--hot) {
    background: #f1f5f9;
    color: var(--color-text);
    border-color: transparent;
  }
  :global(.sw-tag--hot:hover) {
    background: var(--color-primary-dim);
    border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);
    color: var(--color-primary);
  }
  :global(.sw-tag-zh) {
    font-weight: 600;
    letter-spacing: .02em;
  }
  :global(.sw-tag-vi) {
    font-size: .72rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  :global(.sw-tag--hot:hover .sw-tag-vi) { color: color-mix(in srgb, var(--color-primary) 70%, transparent); }

  /* History tag */
  :global(.sw-tag--hist) {
    background: #f8fafc;
    color: var(--color-text);
    border-color: var(--color-border);
    gap: .4rem;
  }
  :global(.sw-tag--hist:hover) {
    background: var(--color-primary-dim);
    border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
    color: var(--color-primary);
  }
  :global(.sw-tag-remove) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px; height: 14px;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: 10px;
    line-height: 1;
    padding: 0;
    transition: background .12s, color .12s;
    flex-shrink: 0;
  }
  :global(.sw-tag-remove:hover) { background: #ef4444; color: #fff; }

  /* Empty state */
  .sw-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: .2rem;
    padding: .5rem 1rem 1rem;
    text-align: center;
  }
  .sw-empty-icon { color: var(--color-border); margin-bottom: .25rem; }
  .sw-empty-text {
    font-size: .83rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }
  .sw-empty-sub {
    font-size: .73rem;
    color: var(--color-border);
  }
</style>

<!-- ─────────────────── SCRIPT ──────────────────────────────────────────── -->
<script>
  const QHIST_KEY  = 'wz-qhistory';
  const MAX_QHIST  = 10;
  const MIN_QLEN   = 2;

  // ── Storage helpers ─────────────────────────────────────────────────────
  function loadQHist(): string[] {
    try { return JSON.parse(localStorage.getItem(QHIST_KEY) ?? '[]'); }
    catch { return []; }
  }
  function saveQHist(arr: string[]): void {
    try { localStorage.setItem(QHIST_KEY, JSON.stringify(arr)); }
    catch { /* quota / private mode */ }
  }

  function addQuery(q: string): void {
    q = q.trim();
    if (q.length < MIN_QLEN) return;
    const arr = loadQHist().filter(x => x !== q);
    arr.unshift(q);
    saveQHist(arr.slice(0, MAX_QHIST));
    renderHistory();
  }

  function removeQuery(q: string): void {
    saveQHist(loadQHist().filter(x => x !== q));
    renderHistory();
  }

  function clearQHist(): void {
    localStorage.removeItem(QHIST_KEY);
    renderHistory();
  }

  // ── Trigger search ───────────────────────────────────────────────────────
  function triggerSearch(q: string): void {
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    if (!input) return;
    input.value = q;
    input.dispatchEvent(new Event('input', { bubbles: true }));
    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement | null;
    if (clearBtn) clearBtn.hidden = false;
    document.querySelector<HTMLElement>('.hero')
      ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => input.focus(), 280);
  }

  // ── Render history tags ──────────────────────────────────────────────────
  function renderHistory(): void {
    const tagsEl  = document.getElementById('sw-hist-tags')!;
    const emptyEl = document.getElementById('sw-hist-empty')!;
    const clearBtn = document.getElementById('sw-clear-hist') as HTMLButtonElement;

    const hist = loadQHist();

    if (hist.length === 0) {
      tagsEl.innerHTML  = '';
      emptyEl.style.display = '';
      clearBtn.hidden   = true;
      return;
    }

    emptyEl.style.display = 'none';
    clearBtn.hidden = false;

    tagsEl.innerHTML = '';
    hist.forEach(q => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'sw-tag sw-tag--hist';
      btn.setAttribute('role', 'listitem');
      btn.setAttribute('data-query', q);
      btn.setAttribute('aria-label', `Tìm lại: ${q}`);
      btn.innerHTML = `
        <span lang="auto">${q}</span>
        <span class="sw-tag-remove" data-remove="${q}" aria-label="Xóa ${q}" title="Xóa">
          <svg width="8" height="8" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M2 2l6 6M8 2l-6 6"/>
          </svg>
        </span>
      `;
      tagsEl.appendChild(btn);
    });
  }

  // ── Wire up hot keyword tags (rendered server-side) ──────────────────────
  document.querySelectorAll<HTMLButtonElement>('.sw-tag--hot').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.dataset.query ?? '';
      if (q) triggerSearch(q);
    });
  });

  // ── Wire up history tag container (event delegation) ────────────────────
  document.getElementById('sw-hist-tags')?.addEventListener('click', e => {
    const removeTarget = (e.target as Element).closest<HTMLElement>('[data-remove]');
    if (removeTarget) {
      e.stopPropagation();
      removeQuery(removeTarget.dataset.remove ?? '');
      return;
    }
    const tagBtn = (e.target as Element).closest<HTMLButtonElement>('[data-query]');
    if (tagBtn?.dataset.query) triggerSearch(tagBtn.dataset.query);
  });

  // ── Clear all ────────────────────────────────────────────────────────────
  document.getElementById('sw-clear-hist')?.addEventListener('click', () => {
    clearQHist();
  });

  // ── Auto-save queries when user searches ─────────────────────────────────
  // Debounce: save after 1.4s of inactivity (not on every keystroke)
  let saveTimer: ReturnType<typeof setTimeout> | null = null;
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.trim();
    if (saveTimer) clearTimeout(saveTimer);
    if (q.length >= MIN_QLEN) {
      saveTimer = setTimeout(() => addQuery(q), 1400);
    }
  });

  // ── Init ─────────────────────────────────────────────────────────────────
  renderHistory();
</script>
