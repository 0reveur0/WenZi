---
/**
 * SearchWidgets — Từ khóa hot + Lịch sử tìm kiếm (bilingual)
 */

const HOT_KEYWORDS = [
  { word: '划船', vi: 'chèo thuyền', en: 'rowing' },
  { word: '真实', vi: 'thật sự', en: 'real, genuine' },
  { word: '爸爸', vi: 'bố, cha', en: 'father, dad' },
  { word: '粽子', vi: 'bánh chưng', en: 'sticky rice dumpling' },
  { word: '责任', vi: 'trách nhiệm', en: 'responsibility' },
  { word: '新闻', vi: 'tin tức', en: 'news' },
  { word: '夏天', vi: 'mùa hè', en: 'summer' },
  { word: '关心', vi: 'quan tâm', en: 'to care about' },
  { word: '报道', vi: 'đưa tin', en: 'to report' },
  { word: '记者', vi: 'phóng viên', en: 'journalist' },
];
---

<div class="sw-grid">

  <!-- ── Card 1: Từ khóa hot ───────────────────────────────────────────── -->
  <div class="sw-card">
    <div class="sw-header">
      <h2 class="sw-title" id="sw-hot-title">Từ khóa hot</h2>
      <span class="sw-badge">{HOT_KEYWORDS.length}</span>
    </div>

    <div class="sw-tags-wrap" role="list" aria-label="Danh sách từ khóa hot" id="sw-hot-tags">
      {HOT_KEYWORDS.map((k, i) => (
        <button
          class="sw-tag sw-tag--hot"
          type="button"
          role="listitem"
          data-query={k.word}
          data-note-vi={k.vi}
          data-note-en={k.en}
          title={k.vi}
          aria-label={`${k.word} — ${k.vi}`}
        >
          <span class="sw-tag-zh" lang="zh">{k.word}</span>
          <span class="sw-tag-sep" aria-hidden="true">·</span>
          <span class="sw-tag-note">{k.vi}</span>
        </button>
      ))}
    </div>
  </div>

  <!-- ── Card 2: Lịch sử tìm kiếm ─────────────────────────────────────── -->
  <div class="sw-card">
    <div class="sw-header">
      <h2 class="sw-title" id="sw-hist-title">Lịch sử</h2>
      <button class="sw-clear-btn" id="sw-clear-hist" type="button"
        aria-label="Xóa lịch sử tìm kiếm" hidden>Xóa tất cả</button>
    </div>

    <!-- State A: not logged in (default; hidden by JS when logged in) -->
    <div class="sw-guest-notice" id="sw-guest-notice">
      <p class="sw-guest-title" id="sw-guest-title">Yêu cầu đăng nhập</p>
      <p class="sw-guest-body" id="sw-guest-body">
        Vui lòng đăng nhập tài khoản để hệ thống kích hoạt tính năng lưu giữ
        dữ liệu lịch sử tra cứu của bạn.
      </p>
    </div>

    <!-- State B: logged in, empty (hidden by default) -->
    <p class="sw-logged-empty" id="sw-logged-empty" hidden>
      Hệ thống chưa ghi nhận dữ liệu lịch sử tra cứu của bạn.
    </p>

    <!-- State C: logged in, has data — tags rendered by JS -->
    <div class="sw-tags-wrap" id="sw-hist-tags"
      role="list" aria-label="Lịch sử tìm kiếm" aria-live="polite"></div>
  </div>

</div>

<!-- ──────────────────────── STYLES ──────────────────────────────────── -->
<style>
  .sw-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: .75rem;
    margin-bottom: 1.25rem;
  }
  @media (min-width: 600px) {
    .sw-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Card shell */
  .sw-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 22px;
    box-shadow: var(--shadow-sm);
    padding: 1.3rem 1.4rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 160px;
  }

  /* Header row */
  .sw-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
  }
  .sw-title {
    font-size: .93rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .sw-badge {
    font-size: .68rem;
    font-weight: 700;
    background: var(--color-primary);
    color: #fff;
    border-radius: 999px;
    padding: .1rem .48rem;
    min-width: 20px;
    text-align: center;
    line-height: 1.6;
    flex-shrink: 0;
  }
  .sw-clear-btn {
    font-size: .72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: none;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    padding: .2rem .6rem;
    cursor: pointer;
    transition: color .15s, border-color .15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .sw-clear-btn:hover { color: #ef4444; border-color: #ef4444; }

  /* Tags wrapper */
  .sw-tags-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    align-content: flex-start;
  }

  /* Tag — shared */
  :global(.sw-tag) {
    display: inline-flex;
    align-items: center;
    gap: .28rem;
    padding: .38rem .82rem;
    border-radius: 999px;
    border: 1.5px solid transparent;
    font-size: .82rem;
    cursor: pointer;
    transition: background .15s, border-color .15s, color .15s, transform .1s;
    line-height: 1.25;
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
    background: none;
  }
  :global(.sw-tag:active) { transform: scale(.93); }

  /* Hot keyword tag */
  :global(.sw-tag--hot) {
    background: #f1f5f9;
    color: var(--color-text);
  }
  :global(.sw-tag--hot:hover) {
    background: var(--color-primary-dim);
    border-color: color-mix(in srgb, var(--color-primary) 28%, transparent);
    color: var(--color-primary);
  }
  :global(.sw-tag-zh) {
    font-weight: 600;
    letter-spacing: .02em;
  }
  :global(.sw-tag-sep) {
    color: #cbd5e1;
    font-size: .72rem;
  }
  :global(.sw-tag-note) {
    font-size: .73rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
  :global(.sw-tag--hot:hover .sw-tag-sep),
  :global(.sw-tag--hot:hover .sw-tag-note) {
    color: color-mix(in srgb, var(--color-primary) 60%, transparent);
  }

  /* History tag */
  :global(.sw-tag--hist) {
    background: #f8fafc;
    color: var(--color-text);
    border-color: var(--color-border);
    gap: .42rem;
  }
  :global(.sw-tag--hist:hover) {
    background: var(--color-primary-dim);
    border-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
    color: var(--color-primary);
  }

  /* × remove button inside history tag */
  :global(.sw-tag-remove) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 15px; height: 15px;
    border-radius: 50%;
    border: none;
    background: #e2e8f0;
    color: #94a3b8;
    font-size: .65rem;
    font-weight: 700;
    line-height: 1;
    padding: 0;
    cursor: pointer;
    transition: background .12s, color .12s;
    flex-shrink: 0;
  }
  :global(.sw-tag-remove:hover) { background: #ef4444; color: #fff; }

  /* ── State A: not logged in ── */
  .sw-guest-notice {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .35rem;
    background: #f9fafb;
    border: 1.5px dashed #e2e8f0;
    border-radius: 14px;
    padding: 1rem 1.1rem;
    text-align: center;
  }
  .sw-guest-title {
    font-size: .72rem;
    font-weight: 700;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: .07em;
  }
  .sw-guest-body {
    font-size: .8rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
  }

  /* ── State B: logged in, empty ── */
  .sw-logged-empty {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .83rem;
    color: #9ca3af;
    font-style: italic;
    text-align: center;
    padding: 1.25rem .5rem;
    margin: 0;
  }
</style>

<!-- ──────────────────────── SCRIPT ──────────────────────────────────── -->
<script>
  const AUTH_KEY  = 'wz-user';
  const QHIST_KEY = 'wz-qhistory';
  const LANG_KEY  = 'wz-lang';
  const MAX_QHIST = 10;
  const MIN_QLEN  = 2;

  // ── Language helpers ──────────────────────────────────────────────────────
  function getLang(): string {
    try { return localStorage.getItem(LANG_KEY) || 'vi'; }
    catch { return 'vi'; }
  }

  const SW_UI = {
    vi: {
      hotTitle: 'Từ khóa hot',
      histTitle: 'Lịch sử',
      clearAll: 'Xóa tất cả',
      loginRequired: 'Yêu cầu đăng nhập',
      loginBody: 'Vui lòng đăng nhập tài khoản để hệ thống kích hoạt tính năng lưu giữ dữ liệu lịch sử tra cứu của bạn.',
      histEmpty: 'Hệ thống chưa ghi nhận dữ liệu lịch sử tra cứu của bạn.',
      searchAgain: 'Tìm lại',
      remove: 'Xóa',
    },
    en: {
      hotTitle: 'Hot keywords',
      histTitle: 'History',
      clearAll: 'Clear all',
      loginRequired: 'Login required',
      loginBody: 'Please log in to enable search history saving.',
      histEmpty: 'No search history recorded yet.',
      searchAgain: 'Search again',
      remove: 'Remove',
    },
  };

  function applyLangUI(lang: string) {
    const ui = (SW_UI as any)[lang] || SW_UI.vi;
    const hotTitle = document.getElementById('sw-hot-title');
    if (hotTitle) hotTitle.textContent = ui.hotTitle;
    const histTitle = document.getElementById('sw-hist-title');
    if (histTitle) histTitle.textContent = ui.histTitle;
    const clearBtn = document.getElementById('sw-clear-hist') as HTMLButtonElement | null;
    if (clearBtn) clearBtn.textContent = ui.clearAll;
    const guestTitle = document.getElementById('sw-guest-title');
    if (guestTitle) guestTitle.textContent = ui.loginRequired;
    const guestBody = document.getElementById('sw-guest-body');
    if (guestBody) guestBody.textContent = ui.loginBody;
    const emptyMsg = document.getElementById('sw-logged-empty');
    if (emptyMsg) emptyMsg.textContent = ui.histEmpty;

    // Update hot keyword notes
    document.querySelectorAll<HTMLButtonElement>('.sw-tag--hot').forEach(btn => {
      const note = btn.querySelector('.sw-tag-note');
      if (note) {
        note.textContent = lang === 'en'
          ? (btn.dataset.noteEn || btn.dataset.noteVi || '')
          : (btn.dataset.noteVi || btn.dataset.noteEn || '');
      }
      const noteVal = lang === 'en'
        ? (btn.dataset.noteEn || btn.dataset.noteVi || '')
        : (btn.dataset.noteVi || btn.dataset.noteEn || '');
      btn.title = noteVal;
      btn.setAttribute('aria-label', `${btn.dataset.query} — ${noteVal}`);
    });
  }

  // ── Auth helpers ──────────────────────────────────────────────────────────
  function getUser(): string | null {
    try { return localStorage.getItem(AUTH_KEY); }
    catch { return null; }
  }

  // ── Storage helpers ───────────────────────────────────────────────────────
  function loadQHist(): string[] {
    try { return JSON.parse(localStorage.getItem(QHIST_KEY) ?? '[]'); }
    catch { return []; }
  }
  function saveQHist(arr: string[]) {
    try { localStorage.setItem(QHIST_KEY, JSON.stringify(arr)); }
    catch { /* quota / private mode */ }
  }
  function addQuery(q: string) {
    q = q.trim();
    if (!getUser() || q.length < MIN_QLEN) return;
    const arr = loadQHist().filter(x => x !== q);
    arr.unshift(q);
    saveQHist(arr.slice(0, MAX_QHIST));
    renderHistory();
  }
  function removeQuery(q: string) {
    saveQHist(loadQHist().filter(x => x !== q));
    renderHistory();
  }
  function clearQHist() {
    localStorage.removeItem(QHIST_KEY);
    renderHistory();
  }

  // ── Trigger search ────────────────────────────────────────────────────────
  function triggerSearch(q: string) {
    const input    = document.getElementById('search-input') as HTMLInputElement | null;
    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement | null;
    if (!input) return;
    input.value = q;
    input.dispatchEvent(new Event('input', { bubbles: true }));
    if (clearBtn) clearBtn.hidden = false;
    document.querySelector<HTMLElement>('.hero')
      ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => input.focus(), 280);
  }

  // ── Render history section ────────────────────────────────────────────────
  function renderHistory() {
    const lang     = getLang();
    const ui       = (SW_UI as any)[lang] || SW_UI.vi;
    const guestEl  = document.getElementById('sw-guest-notice')!;
    const emptyEl  = document.getElementById('sw-logged-empty')!;
    const tagsEl   = document.getElementById('sw-hist-tags')!;
    const clearBtn = document.getElementById('sw-clear-hist') as HTMLButtonElement;

    const user = getUser();

    if (!user) {
      guestEl.hidden = false;
      emptyEl.hidden = true;
      tagsEl.innerHTML = '';
      clearBtn.hidden  = true;
      return;
    }

    guestEl.hidden = true;
    const hist = loadQHist();

    if (hist.length === 0) {
      emptyEl.hidden   = false;
      tagsEl.innerHTML = '';
      clearBtn.hidden  = true;
      return;
    }

    emptyEl.hidden  = true;
    clearBtn.hidden = false;
    tagsEl.innerHTML = '';

    hist.forEach(q => {
      const btn = document.createElement('button');
      btn.type      = 'button';
      btn.className = 'sw-tag sw-tag--hist';
      btn.setAttribute('role', 'listitem');
      btn.setAttribute('data-query', q);
      btn.setAttribute('aria-label', `${ui.searchAgain}: ${q}`);
      btn.innerHTML = `
        <span lang="auto">${q}</span>
        <span class="sw-tag-remove" data-remove="${q}"
          aria-label="${ui.remove} ${q}" title="${ui.remove}" role="button">✕</span>
      `;
      tagsEl.appendChild(btn);
    });
  }

  // ── Wire hot keyword tags ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.sw-tag--hot').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.dataset.query ?? '';
      if (q) triggerSearch(q);
    });
  });

  // ── Wire history container (event delegation) ─────────────────────────────
  document.getElementById('sw-hist-tags')?.addEventListener('click', e => {
    const removeEl = (e.target as Element).closest<HTMLElement>('[data-remove]');
    if (removeEl) {
      e.stopPropagation();
      removeQuery(removeEl.dataset.remove ?? '');
      return;
    }
    const tagBtn = (e.target as Element).closest<HTMLButtonElement>('[data-query]');
    if (tagBtn?.dataset.query) triggerSearch(tagBtn.dataset.query);
  });

  // ── Clear all button ──────────────────────────────────────────────────────
  document.getElementById('sw-clear-hist')?.addEventListener('click', clearQHist);

  // ── Auto-save queries after 1.4 s of inactivity (only when logged in) ────
  let saveTimer: ReturnType<typeof setTimeout> | null = null;
  document.getElementById('search-input')?.addEventListener('input', e => {
    const q = (e.target as HTMLInputElement).value.trim();
    if (saveTimer) clearTimeout(saveTimer);
    if (getUser() && q.length >= MIN_QLEN) {
      saveTimer = setTimeout(() => addQuery(q), 1400);
    }
  });

  // ── React to auth changes from Header ────────────────────────────────────
  document.addEventListener('wz:authchange', () => renderHistory());

  // ── React to language changes ─────────────────────────────────────────────
  window.addEventListener('wz:langchange', (e: Event) => {
    const lang = (e as CustomEvent).detail?.lang || getLang();
    applyLangUI(lang);
    renderHistory();
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  applyLangUI(getLang());
  renderHistory();
</script>
