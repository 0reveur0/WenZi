---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'WenZi — Từ điển Hán Việt',
  description = 'Từ điển Hán Việt đơn giản và hiệu quả.',
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <style is:global>
      :root {
        --color-bg:            #f8fafc;
        --color-surface:       #ffffff;
        --color-border:        #e2e8f0;
        --color-text:          #1e293b;
        --color-text-muted:    #475569;
        --color-primary:       #2b4c7e;
        --color-primary-dim:   #eef2f8;
        --color-primary-hover: #1e3a63;
        --shadow-sm: 0 1px 4px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
        --shadow-md: 0 4px 24px rgba(0,0,0,.09), 0 1px 4px rgba(0,0,0,.05);
        --shadow-lg: 0 8px 40px rgba(0,0,0,.11), 0 2px 8px rgba(0,0,0,.06);
        --radius-sm:  10px;
        --radius-md:  16px;
        --radius-lg:  24px;
        --radius-xl:  32px;
        --font-sans:  'Inter', system-ui, -apple-system, sans-serif;
        --font-mono:  'JetBrains Mono', ui-monospace, monospace;
        /* Typography scale */
        --text-xs:    0.75rem;
        --text-sm:    0.875rem;
        --text-base:  1rem;
        --text-lg:    1.125rem;
        --text-xl:    1.25rem;
        --text-2xl:   1.5rem;
        --lh-tight:   1.4;
        --lh-normal:  1.7;
        --lh-relaxed: 1.85;
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme='light']) {
          --color-bg:            #0d1520;
          --color-surface:       #162032;
          --color-border:        #1e2d42;
          --color-text:          #e2e8f0;
          --color-text-muted:    #7f98b8;
          --color-primary:       #5b8ad4;
          --color-primary-dim:   #162038;
          --color-primary-hover: #7ba4e0;
          --shadow-sm: 0 1px 4px rgba(0,0,0,.45);
          --shadow-md: 0 4px 24px rgba(0,0,0,.55);
          --shadow-lg: 0 8px 40px rgba(0,0,0,.65);
        }
      }

      [data-theme='dark'] {
        --color-bg:            #0d1520;
        --color-surface:       #162032;
        --color-border:        #1e2d42;
        --color-text:          #e2e8f0;
        --color-text-muted:    #7f98b8;
        --color-primary:       #5b8ad4;
        --color-primary-dim:   #162038;
        --color-primary-hover: #7ba4e0;
        --shadow-sm: 0 1px 4px rgba(0,0,0,.45);
        --shadow-md: 0 4px 24px rgba(0,0,0,.55);
        --shadow-lg: 0 8px 40px rgba(0,0,0,.65);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-sans);
        background: var(--color-bg);
        color: var(--color-text);
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        line-height: var(--lh-normal);
        font-size: 1rem;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        transition: background 0.2s, color 0.2s;
      }

      main { flex: 1; }
      a { color: var(--color-primary); text-decoration: none; }
      a:hover { text-decoration: underline; }
      img, svg { display: block; max-width: 100%; }

      /* Global focus visible for accessibility */
      :focus-visible {
        outline: 2.5px solid var(--color-primary);
        outline-offset: 2px;
        border-radius: 4px;
      }

      ::selection {
        background: var(--color-primary);
        color: #fff;
      }

      /* Hanzi font rendering — smoother on all platforms */
      [lang='zh'] {
        font-family: 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', 'SimSun', serif;
        font-weight: 400;
      }
    </style>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('wz-theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.setAttribute('data-theme', 'light');
        }
        const lang = localStorage.getItem('wz-lang') || 'vi';
        document.documentElement.setAttribute('data-lang', lang);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
